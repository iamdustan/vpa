---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service | Virtual Pacing Academy" description="The terms and conditions for participating in the Virtual Pacing Academy.">
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-4xl bg-background rounded-[40px] border border-white/5 p-12 lg:p-24 text-white/60">
			<h1 class="text-3xl md:text-5xl font-black text-white tracking-tighter uppercase mb-12">Terms of Service</h1>
			<div class="space-y-8">
                <p>By using our website and applying for the Virtual Pacing Academy, you agree to the following terms and conditions.</p>
                <h2 class="text-xl font-bold text-white uppercase">1. Academy Participation</h2>
                <p>Participation in the academy requires a commitment to the curriculum and mentorship sessions. We reserve the right to remove students who do not meet these commitments.</p>
                <h2 class="text-xl font-bold text-white uppercase">2. Intellectual Property</h2>
                <p>All materials provided during the academy are the property of Virtual Pacing Academy and may not be redistributed without permission.</p>
            </div>
		</div>
	</section>
</BaseLayout>
