---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service | Virtual Pacing Academy" description="The terms and conditions for participating in the Virtual Pacing Academy.">

	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-4xl bg-background rounded-[40px] border border-white/5 p-12 lg:p-24 overflow-hidden relative">
            <div class="absolute inset-0 bg-brand-blue/5 blur-[120px] -z-10"></div>

			<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Legal</h2>
			<h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase mb-12">Terms of <span class="text-gradient">Service</span></h1>

			<div class="space-y-12 text-white/60 leading-relaxed font-medium">
				<div class="space-y-4">
					<p class="text-lg text-white/80">By using our website and applying for the Virtual Pacing Academy, you agree to the following terms and conditions.</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-xl font-black text-white uppercase tracking-tight">1. Academy Participation</h2>
					<p>Participation in the academy requires a commitment to the curriculum and mentorship sessions. We reserve the right to remove students who do not meet these commitments or who violate our code of conduct.</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-xl font-black text-white uppercase tracking-tight">2. Intellectual Property</h2>
					<p>All materials provided during the academy—including videos, documents, and clinical case studies—are the exclusive property of Virtual Pacing Academy and may not be redistributed or repurposed without explicit permission.</p>
				</div>

				<div class="space-y-4">
					<h2 class="text-xl font-black text-white uppercase tracking-tight">3. Limitation of Liability</h2>
					<p>While we strive to provide the best possible education and career placement support, we do not guarantee employment or specific salary outcomes.</p>
				</div>
			</div>

			<div class="mt-20 pt-12 border-t border-white/5">
				<p class="text-[10px] font-black uppercase tracking-widest text-white/20">Last Updated: May 2026</p>
			</div>
		</div>
	</section>

</BaseLayout>
