---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Virtual Pacing Academy | The Mentorship Bridge">
	<section class="relative flex h-[90vh] items-center justify-center overflow-hidden px-4">
		<div class="z-10 text-center">
			<h1 class="text-5xl font-extrabold tracking-tight sm:text-7xl">
				The Mentorship <span class="bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">Bridge</span>
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 sm:text-xl">
				From where you are to where you want to be. Master the technical skills and gain the mentorship needed to break into the MedTech industry.
			</p>
			<div class="mt-10 flex flex-wrap justify-center gap-4">
				<a href="/apply" class="rounded-full bg-white px-8 py-4 text-lg font-bold text-slate-950 transition-all hover:scale-105 hover:bg-slate-200">
					Start Your Journey
				</a>
				<a href="/curriculum" class="rounded-full border border-white/20 px-8 py-4 text-lg font-bold text-white transition-all hover:bg-white/5">
					View Curriculum
				</a>
			</div>
		</div>
		
		{/* Animated background elements would go here */}
		<div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_50%,rgba(99,102,241,0.1),transparent_50%)]"></div>
	</section>

	<section class="py-24" id="journey">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Your Transformation</h2>
				<p class="mt-4 text-lg text-slate-400">A clear, supported path to a high-impact career.</p>
			</div>
			
			<div class="mt-20 grid gap-12 md:grid-cols-3">
				<div class="group relative rounded-2xl border border-white/5 bg-white/5 p-8 transition-all hover:bg-white/10">
					<div class="text-4xl font-black text-indigo-500/20 group-hover:text-indigo-500/40 transition-colors">01</div>
					<h3 class="mt-4 text-xl font-bold text-white">Apply & Connect</h3>
					<p class="mt-2 text-slate-400">Join a community of driven individuals and veteran mentors focused on your success.</p>
				</div>
				<div class="group relative rounded-2xl border border-white/5 bg-white/5 p-8 transition-all hover:bg-white/10">
					<div class="text-4xl font-black text-cyan-500/20 group-hover:text-cyan-500/40 transition-colors">02</div>
					<h3 class="mt-4 text-xl font-bold text-white">Intensive Learning</h3>
					<p class="mt-2 text-slate-400">Master cardiac pacing and device management through high-touch, virtual sessions.</p>
				</div>
				<div class="group relative rounded-2xl border border-white/5 bg-white/5 p-8 transition-all hover:bg-white/10">
					<div class="text-4xl font-black text-emerald-500/20 group-hover:text-emerald-500/40 transition-colors">03</div>
					<h3 class="mt-4 text-xl font-bold text-white">Career Launch</h3>
					<p class="mt-2 text-slate-400">Get hired as a Clinical Specialist with a network and skill set that lasts a lifetime.</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
