---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Our Mission | Virtual Pacing Academy" description="Learn about the Virtual Pacing Academy mission to lower technical barriers and bridge the mentorship gap in the medical device industry.">
	
	<!-- Mission Section -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] bg-background rounded-[40px] border border-white/5 p-12 lg:p-24 overflow-hidden relative">
            <div class="absolute inset-0 bg-brand-blue/5 blur-[120px] -z-10"></div>
			<div class="grid gap-20 lg:grid-cols-2 items-center">
				<div>
					<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Our Mission</h2>
					<h3 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase mb-8 leading-[0.9]">We build the <br/><span class="text-gradient">Mentorship Bridge.</span></h3>
					<div class="space-y-6">
						<p class="text-xl text-white/60 leading-relaxed font-medium max-w-xl">
							The Virtual Pacing Academy started because we learned that asynchronous online learning was inefficient. It just doesn't work well on its own.
						</p>
						<p class="text-xl text-white/40 leading-relaxed font-medium max-w-xl">
							Virtual learning provides flexibility and levels the playing field for anyone seeking to grow. That's why our model combines virtual efficiency with veteran mentors that coach you every step of the way.
						</p>
					</div>
				</div>
				<div class="grid gap-8">
					<div class="glass-card p-10 bg-white/[0.02] border border-white/5 rounded-3xl">
						<h3 class="text-xl font-black text-white uppercase tracking-tight mb-2">100+ Years Experience</h3>
						<p class="text-white/30 font-medium">Our mentors are industry veterans from Medtronic, Abbott, and Boston Scientific.</p>
					</div>
					<div class="glass-card p-10 bg-white/[0.02] border border-white/5 rounded-3xl">
						<h3 class="text-xl font-black text-brand-blue uppercase tracking-tight mb-2">Partnership, Not a Drop</h3>
						<p class="text-white/30 font-medium">This is not a content drop. We go on the journey with you. We only succeed when you succeed.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Team Section -->
	<section class="py-32 flex flex-col items-center justify-center p-6 lg:p-12 relative overflow-hidden">
		<div class="w-full max-w-[1600px] relative">
			<div class="mb-20">
				<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6 text-center">The Mentors</h2>
				<h3 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase mb-8 leading-[0.9] text-center">Veteran Guidance.</h3>
			</div>
			
			<!-- Scroll Controls -->
			<div class="absolute top-1/2 -left-4 lg:-left-12 z-20 -translate-y-1/2 hidden md:block">
				<button id="prev-mentor" class="p-4 rounded-full bg-white/5 border border-white/10 text-white hover:bg-brand-blue hover:border-brand-blue transition-all group">
					<svg class="w-6 h-6 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"></path></svg>
				</button>
			</div>
			<div class="absolute top-1/2 -right-4 lg:-right-12 z-20 -translate-y-1/2 hidden md:block">
				<button id="next-mentor" class="p-4 rounded-full bg-white/5 border border-white/10 text-white hover:bg-brand-blue hover:border-brand-blue transition-all group">
					<svg class="w-6 h-6 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
				</button>
			</div>

			<!-- Scroll Container with Edge Fades -->
			<div class="relative">
				<div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-page-bg to-transparent z-10 pointer-events-none hidden md:block"></div>
				<div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-page-bg to-transparent z-10 pointer-events-none hidden md:block"></div>
				
				<div id="mentor-scroll" class="flex overflow-x-auto snap-x snap-mandatory gap-8 pb-12 no-scrollbar px-4 lg:px-24">
					{[
						{ 
							name: "Shawn Campbell", 
							role: "Founder", 
							image: `${import.meta.env.BASE_URL}team/shawn-campbell.jpg`,
							bio: "An international subject matter expert with 16 years of experience training industry professionals on complex device topics." 
						},
						{ 
							name: "Lauren Condon", 
							role: "Instructor", 
							image: `${import.meta.env.BASE_URL}team/lauren-condon.jpg`,
							bio: "A Principal Clinical Specialist and engineer with 14 years of experience mentoring new hires at Medtronic." 
						},
						{ 
							name: "Martin Reilly", 
							role: "Instructor", 
							image: `${import.meta.env.BASE_URL}team/martin-reilly.jpg`,
							bio: "An IBHRE-certified industry veteran who has trained over 40 Clinical Specialists during his 21-year career." 
						},
						{ 
							name: "Mary Smith", 
							role: "Senior Clinical Specialist", 
							image: `${import.meta.env.BASE_URL}team/mary-smith.jpg`,
							bio: "A triple-certified (CCDS, RCES, RCIS) expert with 14 years of experience in cardiac care and interventional cardiology." 
						},
						{ 
							name: "Pam Elrod", 
							role: "Technical Field Engineer", 
							image: `${import.meta.env.BASE_URL}team/pam-elrod.png`,
							bio: "Our most experienced mentor, bringing over four decades of cardiac nursing and Medtronic technical field engineering expertise." 
						}
					].map((member, index) => (
						<div 
							class="snap-center shrink-0 w-[300px] md:w-[400px] relative group"
						>
							{/* Constant Staggered Pulse */}
							<div 
								class="absolute -inset-4 bg-brand-blue/5 rounded-[48px] blur-2xl animate-pulse-slow pointer-events-none" 
								style={`animation-delay: ${index * 0.8}s`}
							></div>
							
							{/* Hover Highlight */}
							<div class="absolute -inset-1 bg-brand-blue/20 rounded-[36px] blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
							
							<div class="relative glass-card p-8 bg-white/[0.02] border border-white/5 rounded-[32px] hover:border-brand-blue/30 transition-all duration-500 h-full flex flex-col">
								<div class="w-full aspect-[4/5] rounded-2xl overflow-hidden mb-8 bg-brand-blue/10 grayscale group-hover:grayscale-0 transition-all duration-700">
									<img src={member.image} alt={member.name} class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" />
								</div>
								<h4 class="text-2xl font-black text-white uppercase tracking-tight mb-1">{member.name}</h4>
								<p class="text-brand-blue text-xs font-black uppercase tracking-widest mb-6">{member.role}</p>
								<p class="text-white/40 leading-relaxed font-medium text-sm flex-grow">{member.bio}</p>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Progress Indicator -->
			<div class="mt-8 flex justify-center gap-3">
				{[0, 1, 2, 3, 4].map((_, i) => (
					<div class={`mentor-dot h-1.5 rounded-full transition-all duration-500 bg-white/${i === 0 ? '40' : '10'} ${i === 0 ? 'w-8' : 'w-4'}`} data-index={i}></div>
				))}
			</div>
		</div>
	</section>

	<script>
		const scrollContainer = document.getElementById('mentor-scroll');
		const prevBtn = document.getElementById('prev-mentor');
		const nextBtn = document.getElementById('next-mentor');
		const dots = document.querySelectorAll('.mentor-dot');

		const updateDots = () => {
			const scrollFraction = scrollContainer.scrollLeft / (scrollContainer.scrollWidth - scrollContainer.clientWidth);
			const index = Math.round(scrollFraction * (dots.length - 1));
			
			dots.forEach((dot, i) => {
				if (i === index) {
					dot.classList.add('w-8', 'bg-white/40');
					dot.classList.remove('w-4', 'bg-white/10');
				} else {
					dot.classList.remove('w-8', 'bg-white/40');
					dot.classList.add('w-4', 'bg-white/10');
				}
			});
		};

		scrollContainer?.addEventListener('scroll', updateDots);

		prevBtn?.addEventListener('click', () => {
			scrollContainer?.scrollBy({ left: -400, behavior: 'smooth' });
		});

		nextBtn?.addEventListener('click', () => {
			scrollContainer?.scrollBy({ left: 400, behavior: 'smooth' });
		});
	</script>

	<style>
		.no-scrollbar::-webkit-scrollbar {
			display: none;
		}
		.no-scrollbar {
			-ms-overflow-style: none;
			scrollbar-width: none;
		}
		
		@keyframes pulse-slow {
			0%, 100% { opacity: 0.1; transform: scale(1); }
			50% { opacity: 0.3; transform: scale(1.05); }
		}
		.animate-pulse-slow {
			animation: pulse-slow 4s infinite ease-in-out;
		}
	</style>

	<style>
		.no-scrollbar::-webkit-scrollbar {
			display: none;
		}
		.no-scrollbar {
			-ms-overflow-style: none;
			scrollbar-width: none;
		}
		
		@keyframes pulse-slow {
			0%, 100% { opacity: 0.1; transform: scale(1); }
			50% { opacity: 0.3; transform: scale(1.05); }
		}
		.animate-pulse-slow {
			animation: pulse-slow 4s infinite ease-in-out;
		}
	</style>

	<!-- Reviews Section -->
	<section class="py-32 flex flex-col items-center justify-center p-6 lg:p-12 bg-white/[0.02] relative overflow-hidden">
		<div class="w-full max-w-[1600px] relative">
			<div class="grid lg:grid-cols-2 gap-20 items-center">
				<div>
					<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Success Stories</h2>
					<h3 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase mb-8 leading-[0.9]">What our <br/>students say.</h3>
					<p class="text-xl text-white/40 leading-relaxed font-medium max-w-xl">
						Our graduates have transitioned from diverse backgrounds into high-impact careers at the world's leading medical device companies.
					</p>
					
					<!-- Review Progress Dots -->
					<div class="mt-12 flex gap-3">
						{[0, 1, 2, 3, 4].map((_, i) => (
							<div class={`review-dot h-1.5 rounded-full transition-all duration-500 bg-white/${i === 0 ? '40' : '10'} ${i === 0 ? 'w-8' : 'w-4'}`} data-index={i}></div>
						))}
					</div>
				</div>

				<div class="relative group">
					<div id="review-scroll" class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar cursor-grab active:cursor-grabbing">
						{[
							{ 
								name: "Dan Arellano", 
								image: `${import.meta.env.BASE_URL}reviews/dan-arellano.jpg`,
								text: "Enrolling in VPA allowed me to learn hands-on pacing concepts within the confines of a busy life. Coupling this teaching with my experience, I was able to secure an offer in the competitive CRM field.", 
								author: "Clinical Specialist" 
							},
							{ 
								name: "Joshua Meyer", 
								image: `${import.meta.env.BASE_URL}reviews/joshua-meyer.jpg`,
								text: "The independent lessons followed by 1-on-1 meetings made me confident I was learning exactly what I needed to know. VPA goes above and beyond to provide all the resources necessary for success.", 
								author: "Field Representative" 
							},
							{ 
								name: "Kristie Delgado", 
								image: `${import.meta.env.BASE_URL}reviews/kristie-delgado.jpg`,
								text: "As an applicant undergoing a career change after 20 years in the workforce, I know without a doubt that I would not have this opportunity if not for VPA. The flexibility allowed me to learn while working full time.", 
								author: "Clinical Specialist" 
							},
							{ 
								name: "Ali Alshaher", 
								image: `${import.meta.env.BASE_URL}reviews/ali-alshaher.jpg`,
								text: "I'm way ahead of the curve for new hires. The depth of the curriculum and the quality of the mentorship truly prepares you for the clinical environment from day one.", 
								author: "CRM Specialist" 
							},
							{ 
								name: "Laura Brunet", 
								image: null,
								text: "I cannot say enough good things about VPA and how it’s changed my life, my confidence and me as a person. The support system is unlike any other educational program I've experienced.", 
								author: "Clinical Specialist" 
							}
						].map((review) => (
							<div class="snap-center shrink-0 w-full transition-all duration-700 review-card">
								<div class="glass-card p-12 bg-background border border-white/10 rounded-[40px] relative mx-2 h-full">
									<div class="flex items-center gap-6 mb-8">
										{review.image && (
											<div class="w-16 h-16 rounded-full overflow-hidden border-2 border-brand-blue/30">
												<img src={review.image} alt={review.name} class="w-full h-full object-cover" />
											</div>
										)}
										<div>
											<h4 class="text-xl font-black text-white uppercase tracking-tight">{review.name}</h4>
											<p class="text-xs font-black uppercase tracking-[0.2em] text-brand-blue">{review.author}</p>
										</div>
									</div>
									<div class="text-6xl text-brand-blue/10 font-serif absolute top-12 right-12">"</div>
									<p class="text-xl text-white/70 italic relative z-10 leading-relaxed">
										{review.text}
									</p>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</div>
	</section>

	<script>
		const reviewContainer = document.getElementById('review-scroll');
		const reviewDots = document.querySelectorAll('.review-dot');
		const reviewCards = document.querySelectorAll('.review-card');
		let isUserInteracting = false;
		let scrollInterval: ReturnType<typeof setInterval>;

		const updateReviewDots = () => {
			if (!reviewContainer) return;
			const index = Math.round(reviewContainer.scrollLeft / reviewContainer.clientWidth);
			
			reviewDots.forEach((dot, i) => {
				if (i === index) {
					dot.classList.add('w-8', 'bg-white/40');
					dot.classList.remove('w-4', 'bg-white/10');
				} else {
					dot.classList.remove('w-8', 'bg-white/40');
					dot.classList.add('w-4', 'bg-white/10');
				}
			});

			reviewCards.forEach((card, i) => {
				if (i === index) {
					card.classList.remove('opacity-40', 'scale-95');
					card.classList.add('opacity-100', 'scale-100');
				} else {
					card.classList.add('opacity-40', 'scale-95');
					card.classList.remove('opacity-100', 'scale-100');
				}
			});
		};

		const startAutoScroll = () => {
			scrollInterval = setInterval(() => {
				if (!isUserInteracting && reviewContainer) {
					const nextScroll = (reviewContainer.scrollLeft + reviewContainer.clientWidth + 10) >= reviewContainer.scrollWidth 
						? 0 
						: reviewContainer.scrollLeft + reviewContainer.clientWidth;
					
					reviewContainer.scrollTo({ left: nextScroll, behavior: 'smooth' });
				}
			}, 15000);
		};

		reviewContainer?.addEventListener('scroll', updateReviewDots);
		// Initialize
		updateReviewDots();
		
		const stopInteraction = () => {
			isUserInteracting = true;
			clearInterval(scrollInterval);
		};

		reviewContainer?.addEventListener('mousedown', stopInteraction);
		reviewContainer?.addEventListener('touchstart', stopInteraction, { passive: true });
		reviewContainer?.addEventListener('wheel', stopInteraction, { passive: true });

		startAutoScroll();
	</script>

	<section class="pb-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] bg-brand-blue rounded-[40px] p-16 lg:p-24 text-center relative overflow-hidden shadow-2xl shadow-brand-blue/20">
            <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent pointer-events-none"></div>
			<h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase leading-[0.9]">Ready to <br/>Start?</h2>
			<p class="mt-8 text-lg md:text-xl text-white/70 font-medium max-w-2xl mx-auto">Scholarships are now available. Let's work together to bridge the gap.</p>
			<div class="mt-12">
				<a href={`${import.meta.env.BASE_URL}apply`} class="rounded-full bg-white px-10 py-5 text-xl font-black text-slate-950 transition-all hover:scale-105 inline-block shadow-2xl uppercase tracking-[0.2em]">
					Join the Mission
				</a>
			</div>
		</div>
	</section>

</BaseLayout>
