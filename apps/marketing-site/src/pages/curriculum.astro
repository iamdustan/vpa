---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Curriculum | Virtual Pacing Academy" description="Master cardiac pacing and MedTech clinical expertise with VPA's veteran-led curriculum.">
	<div class="mx-auto max-w-4xl px-4 py-24 sm:px-6 lg:px-8">
		<header class="text-center">
			<h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">Our Curriculum</h1>
			<p class="mt-6 text-lg text-slate-400">
				High-touch mentorship and technical mastery, designed for career-shifters and industry-newcomers.
			</p>
		</header>

		<div class="mt-20 space-y-12">
			<div class="rounded-2xl border border-white/5 bg-white/5 p-8">
				<h2 class="text-2xl font-bold text-white">Advanced Pacing</h2>
				<p class="mt-4 text-slate-400">
					A comprehensive deep-dive into cardiac anatomy, physiology, and the mechanics of pacing. From leadless pacemakers to complex troubleshootings.
				</p>
				<ul class="mt-6 space-y-3 text-slate-300">
					<li class="flex items-center gap-3">
						<span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
						Cardiac Anatomy & Electrophysiology
					</li>
					<li class="flex items-center gap-3">
						<span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
						Sensing & Pacing Fundamentals
					</li>
					<li class="flex items-center gap-3">
						<span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
						Advanced Troubleshooting & EGM Interpretation
					</li>
				</ul>
			</div>

			<div class="rounded-2xl border border-white/5 bg-white/5 p-8">
				<h2 class="text-2xl font-bold text-white">CCDS Exam Prep</h2>
				<p class="mt-4 text-slate-400">
					Get certified. We provide the structured study and expert mentorship needed to pass the IBHRE Certified Cardiac Device Specialist (CCDS) exam.
				</p>
			</div>
			
			<div class="rounded-2xl border border-white/5 bg-white/5 p-8">
				<h2 class="text-2xl font-bold text-white">Mentorship & Career Partnership</h2>
				<p class="mt-4 text-slate-400">
					This is not a "content drop." You get weekly 1-on-1 and small group sessions with mentors who have 100+ combined years of industry experience.
				</p>
			</div>
		</div>

		<div class="mt-20 rounded-2xl bg-indigo-600 p-8 text-center sm:p-12">
			<h2 class="text-3xl font-bold text-white">Ready to change your career?</h2>
			<p class="mt-4 text-indigo-100">Apply for our next cohort and bridge the gap to MedTech.</p>
			<a href="/apply" class="mt-8 inline-block rounded-full bg-white px-8 py-4 font-bold text-indigo-600 transition-all hover:bg-slate-100">
				Apply Now
			</a>
		</div>
	</div>
</BaseLayout>
