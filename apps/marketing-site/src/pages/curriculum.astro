---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Curriculum | Virtual Pacing Academy" description="Master cardiac pacing and MedTech clinical expertise with VPA's veteran-led curriculum.">
	
	<!-- Hero Section -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] text-center">
			<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Our Curriculum</h2>
			<h1 class="text-4xl md:text-6xl font-black text-primary tracking-tighter mb-8 leading-[0.9]">Mastery Through <br/><span class="text-gradient">Mentorship.</span></h1>
			<p class="text-xl text-muted leading-relaxed font-medium max-w-2xl mx-auto">
				High-touch technical mastery, designed for career-shifters and industry-newcomers. We bridge the gap between theory and the operating room.
			</p>
		</div>
	</section>

	<!-- Program Overview -->
	<section class="pb-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] grid gap-8 lg:grid-cols-3">
			{[
				{ title: "Basic Pacing", icon: "01", desc: "16-week foundation taking you from zero knowledge to performing basic device checks and troubleshooting." },
				{ title: "Advanced Pacing", icon: "02", desc: "8-week intensive focusing on complex troubleshooting, leadless pacing, and conduction system pacing." },
				{ title: "CCDS Exam Prep", icon: "03", desc: "6-week rigorous preparation for the IBHRE Certified Cardiac Device Specialist exam." }
			].map(item => (
				<div class="glass-card p-10 bg-surface/10 border border-primary/5 rounded-[32px] relative overflow-hidden group hover:border-brand-blue/30 transition-colors">
					<div class="text-6xl font-black text-primary/5 absolute -top-4 -right-4 group-hover:text-brand-blue/10 transition-colors">{item.icon}</div>
					<h3 class="text-2xl font-black text-primary tracking-tight mb-4 relative z-10">{item.title}</h3>
					<p class="text-muted leading-relaxed font-medium relative z-10">{item.desc}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Detailed Programs -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12 bg-surface/5">
		<div class="w-full max-w-[1600px]">
			<div class="grid gap-20">
				<!-- Basic Pacing -->
				<div class="grid lg:grid-cols-2 gap-12 items-start">
					<div>
						<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Program 01</h2>
						<h3 class="text-3xl font-black text-primary tracking-tight mb-6">Basic Pacing Certification</h3>
						<p class="text-lg text-muted leading-relaxed font-medium mb-8">
							Designed for entry-level staff or career-shifters with zero prior knowledge of cardiac devices. This 16-week program builds the absolute foundations.
						</p>
						<ul class="space-y-4">
							{[
								"Anatomy and Physiology of the Heart",
								"Fundamentals of Sensing and Pacing",
								"Basic Device Checks and Interpretation",
								"Clinical Workflow & Sterile Technique",
								"Mentorship throughout the duration",
								"Permanent access to VPA content"
							].map(item => (
								<li class="flex items-center gap-3 text-secondary font-medium">
									<div class="w-1.5 h-1.5 rounded-full bg-brand-blue"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
					<div class="glass-card p-8 bg-background border border-primary/10 rounded-3xl">
						<div class="aspect-video bg-brand-blue/10 rounded-2xl flex flex-col items-center justify-center mb-6 p-12 text-center">
							<p class="text-brand-blue font-black text-xs uppercase tracking-[0.2em] mb-4">Competency Showcase</p>
							<p class="text-secondary text-sm">Graduates demonstrate full competency in performing basic clinical device evaluations.</p>
						</div>
						<p class="text-sm text-muted italic">"The Basic program took me from knowing nothing to feeling confident in the clinic."</p>
					</div>
				</div>

				<div class="h-px bg-primary/5"></div>

				<!-- Advanced Pacing -->
				<div class="grid lg:grid-cols-2 gap-12 items-start">
					<div class="lg:order-2">
						<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Program 02</h2>
						<h3 class="text-3xl font-black text-primary tracking-tight mb-6">Advanced Pacing Certification</h3>
						<p class="text-lg text-muted leading-relaxed font-medium mb-8">
							An 8-week intensive designed for those ready to become self-sufficient in complex clinical environments. Build on foundation concepts to master advanced technology.
						</p>
						<ul class="space-y-4">
							{[
								"Leadless Pacing (e.g., Micra AV)",
								"Conduction System Pacing",
								"Complex EGM Troubleshooting",
								"Lead Dislodgement Case Studies",
								"Advanced ICD and CRT Management",
								"Mentorship & Troubleshooting Mastery"
							].map(item => (
								<li class="flex items-center gap-3 text-secondary font-medium">
									<div class="w-1.5 h-1.5 rounded-full bg-brand-blue"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
					<div class="glass-card p-8 bg-background border border-primary/10 rounded-3xl lg:order-1">
						<div class="aspect-video bg-brand-blue/10 rounded-2xl flex flex-col items-center justify-center mb-6 p-12 text-center">
							<p class="text-brand-blue font-black text-xs uppercase tracking-[0.2em] mb-4">Advanced Case Study</p>
							<p class="text-secondary text-sm">Mastering the identification of complex lead issues and advanced algorithm optimization.</p>
						</div>
						<p class="text-sm text-muted italic">"Focusing on Leadless and CSP was exactly what I needed to advance my career."</p>
					</div>
				</div>

				<div class="h-px bg-primary/5"></div>

				<!-- CCDS Prep -->
				<div class="grid lg:grid-cols-2 gap-12 items-start">
					<div>
						<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Program 03</h2>
						<h3 class="text-3xl font-black text-primary tracking-tight mb-6">CCDS Exam Preparation</h3>
						<p class="text-lg text-muted leading-relaxed font-medium mb-8">
							Prepare for the IBHRE Certified Cardiac Device Specialist exam—the "Mount Everest" of cardiac device tests—with a modeled 6-week study program.
						</p>
						<ul class="space-y-4">
							{[
								"Modeled after official IBHRE study programs",
								"Concept mastery through mentor support",
								"Comprehensive CRM and EP coverage",
								"Mock exams and structured review",
								"Focus on critical test-taking strategies"
							].map(item => (
								<li class="flex items-center gap-3 text-secondary font-medium">
									<div class="w-1.5 h-1.5 rounded-full bg-brand-blue"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
					<div class="glass-card p-8 bg-background border border-primary/10 rounded-3xl">
						<div class="aspect-video bg-brand-blue/10 rounded-2xl flex flex-col items-center justify-center mb-6 p-12 text-center">
							<p class="text-brand-blue font-black text-xs uppercase tracking-[0.2em] mb-4">Exam Mastery</p>
							<p class="text-secondary text-sm">Rigorous concept validation to ensure you are prepared for the industry's highest certification.</p>
						</div>
						<p class="text-xs text-muted italic">* VPA does not guarantee a passing score on the official IBHRE exam.</p>
					</div>
				</div>

				<div class="h-px bg-primary/5"></div>

				<!-- Placement -->
				<div class="grid lg:grid-cols-2 gap-12 items-center bg-brand-blue/5 p-12 rounded-[40px] border border-brand-blue/20">
					<div>
						<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Clinic Solutions</h2>
						<h3 class="text-3xl font-black text-primary tracking-tight mb-6">Device Technician Placement</h3>
						<p class="text-lg text-secondary leading-relaxed font-medium mb-8">
							Solve immediate staffing shortages. We place VPA graduates directly into clinics to act as on-site mentors, helping you train and onboard your own staff.
						</p>
						<a href={`${import.meta.env.BASE_URL}clinic-solutions`} class="inline-block text-primary font-black uppercase tracking-widest hover:text-brand-blue transition-colors">Inquire About Placement &rarr;</a>
					</div>
					<div class="text-center">
						<p class="text-5xl font-black text-primary tracking-tighter mb-4">Staffing <br/>Solved.</p>
						<p class="text-muted font-medium">Extremely flexible logistical and cost models for busy clinics.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Learning Outcomes -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] bg-brand-blue rounded-[40px] p-16 lg:p-24 text-center relative overflow-hidden shadow-2xl shadow-brand-blue/20">
            <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent pointer-events-none"></div>
			<h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-[0.9]">Ready to <br/>Master the Heart?</h2>
			<p class="mt-8 text-lg md:text-xl text-white/70 font-medium max-w-2xl mx-auto">Join the next cohort and start your journey toward becoming a Clinical Specialist.</p>
			<div class="mt-12">
				<a href={`${import.meta.env.BASE_URL}apply`} class="rounded-full bg-white px-10 py-5 text-xl font-black text-slate-950 transition-all hover:scale-105 inline-block shadow-2xl uppercase tracking-[0.2em]">
					Apply for Next Cohort
				</a>
			</div>
		</div>
	</section>

</BaseLayout>
