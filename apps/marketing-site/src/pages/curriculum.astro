<BaseLayout title="Curriculum | Virtual Pacing Academy" description="Master cardiac pacing and MedTech clinical expertise with VPA's veteran-led curriculum.">
	
	<!-- Hero Section -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] text-center">
			<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">Our Curriculum</h2>
			<h1 class="text-5xl md:text-8xl font-black text-white tracking-tighter uppercase mb-8 leading-[0.8]">Mastery Through <br/><span class="text-gradient">Mentorship.</span></h1>
			<p class="text-xl text-white/40 leading-relaxed font-medium max-w-2xl mx-auto">
				High-touch technical mastery, designed for career-shifters and industry-newcomers. We bridge the gap between theory and the operating room.
			</p>
		</div>
	</section>

	<!-- Program Overview -->
	<section class="pb-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] grid gap-8 lg:grid-cols-3">
			{[
				{ title: "Foundations", icon: "1", desc: "Core cardiac anatomy, electrophysiology, and the fundamentals of medical device technology." },
				{ title: "Advanced Pacing", icon: "2", desc: "Deep-dive into CRM devices, from sensing and pacing to complex EGM interpretation." },
				{ title: "Clinical Mastery", icon: "3", desc: "EP mapping, procedural support, and the professional skills needed to excel in the industry." }
			].map(item => (
				<div class="glass-card p-10 bg-white/[0.02] border border-white/5 rounded-[32px] relative overflow-hidden group hover:border-brand-blue/30 transition-colors">
					<div class="text-6xl font-black text-white/5 absolute -top-4 -right-4 group-hover:text-brand-blue/10 transition-colors">{item.icon}</div>
					<h3 class="text-2xl font-black text-white uppercase tracking-tight mb-4 relative z-10">{item.title}</h3>
					<p class="text-white/40 leading-relaxed font-medium relative z-10">{item.desc}</p>
				</div>
			))}
		</div>
	</section>

	<!-- Detailed Modules -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12 bg-white/[0.02]">
		<div class="w-full max-w-[1600px]">
			<div class="grid gap-20">
				<!-- Module 1 -->
				<div class="grid lg:grid-cols-2 gap-12 items-start">
					<div>
						<h3 class="text-3xl font-black text-white uppercase tracking-tight mb-6">Phase 1: Cardiac Foundations</h3>
						<p class="text-lg text-white/50 leading-relaxed font-medium mb-8">
							Before we touch devices, we master the environment. You'll learn the language of the clinic and the science of the heart.
						</p>
						<ul class="space-y-4">
							{[
								"Advanced Cardiac Anatomy & Physiology",
								"ECG Interpretation & Arrhythmia Recognition",
								"Introduction to Cardiac Rhythm Management",
								"Clinical Environment & Sterile Technique"
							].map(item => (
								<li class="flex items-center gap-3 text-white/70 font-medium">
									<div class="w-1.5 h-1.5 rounded-full bg-brand-blue"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
					<div class="glass-card p-8 bg-background border border-white/10 rounded-3xl">
						<div class="aspect-video bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-6">
							<span class="text-brand-blue font-black text-xs uppercase tracking-[0.2em]">Clinical Simulation Module</span>
						</div>
						<p class="text-sm text-white/40 italic">"The foundations phase ensured I wasn't just memorizing device settings, but actually understanding the 'why' behind the therapy."</p>
					</div>
				</div>

				<div class="h-px bg-white/5"></div>

				<!-- Module 2 -->
				<div class="grid lg:grid-cols-2 gap-12 items-start">
					<div class="lg:order-2">
						<h3 class="text-3xl font-black text-white uppercase tracking-tight mb-6">Phase 2: Advanced CRM</h3>
						<p class="text-lg text-white/50 leading-relaxed font-medium mb-8">
							The core of the academy. We dive deep into the technology from every major manufacturer, including Medtronic, Abbott, and Boston Scientific.
						</p>
						<ul class="space-y-4">
							{[
								"Sensing, Pacing & Capture Thresholds",
								"ICD Therapy & Tachyarrhythmia Management",
								"CRT & Heart Failure Device Optimization",
								"Complex Troubleshooting & EGM Analysis"
							].map(item => (
								<li class="flex items-center gap-3 text-white/70 font-medium">
									<div class="w-1.5 h-1.5 rounded-full bg-brand-blue"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
					<div class="glass-card p-8 bg-background border border-white/10 rounded-3xl lg:order-1">
						<div class="aspect-video bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-6">
							<span class="text-brand-blue font-black text-xs uppercase tracking-[0.2em]">Device Programming Workshop</span>
						</div>
						<p class="text-sm text-white/40 italic">"Weekly 1-on-1 sessions with mentors who have done thousands of implants in the field."</p>
					</div>
				</div>

				<div class="h-px bg-white/5"></div>

				<!-- Module 3 -->
				<div class="grid lg:grid-cols-2 gap-12 items-start">
					<div>
						<h3 class="text-3xl font-black text-white uppercase tracking-tight mb-6">Phase 3: Clinical Career Path</h3>
						<p class="text-lg text-white/50 leading-relaxed font-medium mb-8">
							Bridging the gap to the industry. We focus on IBHRE CCDS certification and the professional skills needed to land the role.
						</p>
						<ul class="space-y-4">
							{[
								"IBHRE CCDS Exam Preparation",
								"EP Mapping & NavX/Carto Fundamentals",
								"Physician Interaction & Case Communication",
								"Career Placement & Interview Mastery"
							].map(item => (
								<li class="flex items-center gap-3 text-white/70 font-medium">
									<div class="w-1.5 h-1.5 rounded-full bg-brand-blue"></div>
									{item}
								</li>
							))}
						</ul>
					</div>
					<div class="glass-card p-8 bg-background border border-white/10 rounded-3xl">
						<div class="aspect-video bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-6">
							<span class="text-brand-blue font-black text-xs uppercase tracking-[0.2em]">Career Placement Strategy</span>
						</div>
						<p class="text-sm text-white/40 italic">"The CCDS prep was incredibly structured. I felt fully prepared going into the exam and the interviews."</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Learning Outcomes -->
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-[1600px] bg-brand-blue rounded-[40px] p-20 lg:p-32 text-center relative overflow-hidden shadow-2xl shadow-brand-blue/20">
            <div class="absolute inset-0 bg-gradient-to-br from-white/10 to-transparent pointer-events-none"></div>
			<h2 class="text-5xl md:text-8xl font-black text-white tracking-tighter uppercase leading-[0.8]">Ready to <br/>Master the Heart?</h2>
			<p class="mt-10 text-xl md:text-2xl text-white/70 font-medium max-w-2xl mx-auto">Join the next cohort and start your journey toward becoming a Clinical Specialist.</p>
			<div class="mt-16">
				<a href={`${import.meta.env.BASE_URL}apply`} class="rounded-full bg-white px-12 py-6 text-2xl font-black text-slate-950 transition-all hover:scale-105 inline-block shadow-2xl uppercase tracking-[0.2em]">
					Apply for Next Cohort
				</a>
			</div>
		</div>
	</section>

</BaseLayout>
