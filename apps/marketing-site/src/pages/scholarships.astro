---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Scholarships | Virtual Pacing Academy" description="Learn about our needs-based scholarships and eligibility requirements.">
	<section class="py-32 flex items-center justify-center p-6 lg:p-12">
		<div class="w-full max-w-2xl bg-background rounded-[40px] border border-white/5 p-12 lg:p-24">
			<h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter uppercase mb-8">Scholarships</h1>
			<p class="text-xl text-white/40 leading-relaxed font-medium mb-8">
				We are committed to making MedTech accessible to everyone. Our scholarships cover up to 50% of the academy cost.
			</p>
            <div class="space-y-6 text-white/60">
                <p>To be eligible, you must meet one or more of the following criteria:</p>
                <ul class="list-disc pl-6 space-y-2">
                    <li>Demonstrated financial need</li>
                    <li>Member of an underrepresented group in MedTech</li>
                    <li>Currently working in a non-technical clinical role (e.g., EMT, Nurse, Tech)</li>
                </ul>
            </div>
            <div class="mt-12">
			    <a href={`${import.meta.env.BASE_URL}apply`} class="text-brand-blue font-black uppercase tracking-widest hover:text-white transition-colors">Start your application &rarr;</a>
            </div>
		</div>
	</section>
</BaseLayout>
