---
interface Props {
  sceneUrl: string;
}

const { sceneUrl } = Astro.props;
---

<div class="relative w-full h-screen overflow-hidden bg-background spline-hero-container">
  {/* Using the official Spline Viewer web component for better stability and performance */}
  <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.59/build/spline-viewer.js"></script>
  
  <div class="absolute inset-0">
    <spline-viewer 
        url={sceneUrl} 
        events-target="global" 
        loading-library="lazy"
        class="w-full h-full"
    ></spline-viewer>
  </div>
  
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="z-10 text-center max-w-5xl px-6">
      <slot />
    </div>
  </div>

  {/* Ambient overlay to ensure text readability */}
  <div class="absolute inset-0 bg-gradient-to-b from-background/20 via-transparent to-background/80 pointer-events-none"></div>
</div>

<style>
  spline-viewer {
    width: 100%;
    height: 100%;
  }
</style>
