---
interface Props {
  sceneUrl: string;
}

const { sceneUrl } = Astro.props;
---

<section class="min-h-screen w-full flex items-center justify-center p-6 lg:p-12">
  <div class="w-full max-w-[1600px] aspect-[16/10] max-h-[90vh] bg-background rounded-[40px] overflow-hidden flex flex-col relative shadow-2xl shadow-black/50 border border-primary/5">
    
    {/* Main Content Area: Split Left/Right */}
    <div class="flex-1 flex flex-col lg:flex-row min-h-0">
      
      {/* Left Segment: Narrative Hook */}
      <div class="w-full lg:w-[45%] p-12 lg:p-20 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-primary/5">
        <slot name="narrative">
          <h1 class="text-5xl md:text-7xl font-black tracking-tight text-primary leading-[0.9] text-gradient">
            The Future of Pacing
          </h1>
          <p class="mt-8 text-xl text-muted font-medium leading-relaxed">
            Master the art of clinical pacing and secure your future.
          </p>
        </slot>
      </div>

      {/* Right Segment: Spline Visual */}
      <div class="flex-1 relative bg-surface/20">
        <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.59/build/spline-viewer.js"></script>
        <spline-viewer 
            url={sceneUrl} 
            events-target="global" 
            loading-library="lazy"
            class="w-full h-full"
        ></spline-viewer>
      </div>

    </div>

    {/* Bottom Segment: Integrated CTAs */}
    <div class="h-24 lg:h-32 border-t border-primary/5 flex items-center px-12 lg:px-20 bg-surface/10">
      <div class="w-full flex items-center justify-between">
        <slot name="bottom">
            <div class="flex flex-col">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-muted">Next Cohort</span>
                <span class="text-sm font-black uppercase text-brand-blue">Summer 2026</span>
            </div>
            <div class="flex gap-6">
                <a href={`${import.meta.env.BASE_URL}curriculum`} class="text-[10px] font-black uppercase tracking-widest text-muted hover:text-primary transition-colors">Explore Curriculum</a>
                <a href={`${import.meta.env.BASE_URL}apply`} class="px-8 py-3 rounded-full bg-brand-blue text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue/90 transition-all shadow-lg shadow-brand-blue/20 text-white">Apply Now</a>
            </div>
        </slot>
      </div>
    </div>

  </div>
</section>

<style>
  spline-viewer {
    width: 100%;
    height: 100%;
  }
</style>
