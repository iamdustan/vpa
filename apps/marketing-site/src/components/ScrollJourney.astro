---
interface Props {
  sceneUrl: string;
  heroTitle: string;
  heroSubtitle: string;
}

const { sceneUrl, heroTitle, heroSubtitle } = Astro.props;

// Helper to split text for character animations
const splitText = (text: string) => {
  return text.split('').map((char) => ({
    char: char === ' ' ? '\u00A0' : char,
    isSpace: char === ' '
  }));
};

const titleParts = heroTitle.split(' ');
const firstWord = titleParts[0]; // Usually "The"
const remainingTitle = titleParts.slice(1).join(' ');
const titleChars = splitText(remainingTitle);
---

<div class="relative w-full bg-page-bg" id="scrolly-journey-wrapper">
  <div id="scrolly-journey-card-container" class="h-screen w-full flex items-center justify-center p-4 md:p-6 lg:p-12 overflow-hidden">
    
    <div class="w-full max-w-[1600px] h-[92vh] lg:h-[95vh] bg-background rounded-3xl lg:rounded-[40px] overflow-hidden flex flex-col relative shadow-2xl shadow-black/50 border border-white/5">
      
      <div class="flex-1 flex flex-col-reverse lg:flex-row min-h-0">
        
        <div class="w-full h-1/2 lg:h-full lg:w-[45%] p-8 md:p-12 lg:p-24 flex flex-col justify-center border-t lg:border-t-0 lg:border-r border-white/5 relative overflow-hidden">
          <div class="relative h-full w-full">
            
            {/* Phase 0: Hero */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-100" id="phase-hero">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6 lg:mb-8">Welcome to VPA</h2>
              <h1 class="text-3xl md:text-5xl lg:text-7xl font-black tracking-tighter text-white leading-[0.9] text-gradient uppercase flex flex-wrap">
                <span class="mr-[0.2em]">{firstWord}</span>
                <span class="flex flip-container">
                  {titleChars.map(({ char, isSpace }) => (
                    <span class={`flip-char inline-block ${isSpace ? 'mr-[0.2em]' : ''}`} style="perspective: 1000px;">
                      <span class="inline-block inner-char">{char}</span>
                    </span>
                  ))}
                </span>
              </h1>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/50 font-medium leading-relaxed max-w-sm">
                {heroSubtitle}
              </p>
            </div>

            {/* Phase 1: Problem */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-problem">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6 lg:mb-8">The Problem</h2>
              <h3 class="text-3xl md:text-5xl lg:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Education <br/><span class="text-gradient">is broken.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                Traditional schools cost $30k and take a year. Standard online courses leave you isolated. 
              </p>
            </div>

            {/* Phase 2: Solution */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-solution">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-yellow mb-6 lg:mb-8">The Solution</h2>
              <h3 class="text-3xl md:text-5xl lg:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Mentorship <br/><span class="text-brand-yellow">is the key.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                We pair you with industry veterans who coach you through every single step of your transition.
              </p>
            </div>

            {/* Phase 3: Outcome */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-outcome">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-emerald-400 mb-6 lg:mb-8">The Outcome</h2>
              <h3 class="text-3xl md:text-5xl lg:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Land the <br/><span class="text-emerald-400">Dream Job.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                From the first rhythm to your first day in the OR, we guide you to a career with purpose.
              </p>
            </div>

          </div>
        </div>

        <div class="flex-1 relative bg-surface/10 flex items-center justify-center overflow-hidden">
            <div class="visual-phase absolute inset-0 opacity-100" id="visual-hero">
                <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.59/build/spline-viewer.js"></script>
                <spline-viewer 
                    url={sceneUrl} 
                    events-target="global" 
                    loading-library="lazy"
                    class="w-full h-full"
                ></spline-viewer>
            </div>

            <div class="absolute inset-0 flex items-center justify-center p-6 lg:p-20">
                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-problem">
                    <div class="w-32 h-32 md:w-48 md:h-48 rounded-full border border-white/5 flex items-center justify-center relative">
                        <div class="absolute inset-0 border border-brand-blue/20 rounded-full animate-ping"></div>
                        <div class="w-16 md:w-24 h-px bg-white/20 rotate-45"></div>
                        <div class="w-16 md:w-24 h-px bg-white/20 -rotate-45"></div>
                    </div>
                </div>

                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-solution">
                    <div class="flex items-center gap-4 md:gap-12">
                        <div class="w-16 h-16 md:w-24 md:h-24 rounded-2xl md:rounded-3xl bg-brand-yellow/10 border border-brand-yellow/30 flex items-center justify-center font-black text-brand-yellow uppercase text-[8px] md:text-xs">Student</div>
                        <div class="w-6 md:w-12 h-px bg-white/10 relative">
                            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-brand-yellow"></div>
                        </div>
                        <div class="w-24 h-24 md:w-32 md:h-32 rounded-full border-2 border-brand-blue border-dashed animate-[spin_10s_linear_infinite] p-2">
                            <div class="w-full h-full rounded-full bg-brand-blue/20 flex items-center justify-center font-black text-white uppercase text-[8px] md:text-[10px] text-center">Mentor</div>
                        </div>
                    </div>
                </div>

                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-outcome">
                    <div class="text-center relative">
                        <div class="text-7xl md:text-9xl mb-4 md:mb-8 opacity-20 blur-sm absolute inset-0 translate-y-4">🏆</div>
                        <div class="text-7xl md:text-9xl relative">🏆</div>
                        <div class="mt-4 md:mt-8 text-[10px] md:text-xs font-black uppercase tracking-[0.5em] text-emerald-400">Success Attained</div>
                    </div>
                </div>
            </div>
        </div>

      </div>

      <div class="h-auto lg:h-32 border-t border-white/5 bg-surface/20 px-6 py-4 lg:py-0 lg:px-20">
        <div class="h-full w-full mx-auto flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
          <div class="flex flex-col text-center md:text-left w-full md:w-auto">
              <span class="text-[8px] lg:text-[10px] font-black uppercase tracking-[0.2em] text-white/30">Journey Phase</span>
              <span class="text-xs lg:text-sm font-black uppercase text-brand-blue transition-colors duration-500" id="journey-phase-label">Virtual Pacing Academy</span>
          </div>

          <div class="flex flex-col md:flex-row gap-4 lg:gap-8 items-center w-full md:w-auto">
              <a href={`${import.meta.env.BASE_URL}curriculum`} class="text-[8px] lg:text-[10px] font-black uppercase tracking-widest text-white/70 hover:text-white transition-colors w-full md:w-auto text-center border border-white/10 md:border-none rounded-full px-6 py-3 md:p-0">Explore Curriculum</a>
              <a href={`${import.meta.env.BASE_URL}apply`} class="w-full md:w-auto px-10 py-3 lg:py-4 rounded-full bg-brand-blue text-[8px] lg:text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue/90 transition-all shadow-xl shadow-brand-blue/20 text-center">Apply Now</a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="h-[500vh] pointer-events-none"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const wrapper = document.querySelector('#scrolly-journey-wrapper');
    const cardContainer = document.querySelector('#scrolly-journey-card-container');
    if (!wrapper || !cardContainer) return;

    // Initial Flip Animation for Hero Title
    const flipChars = document.querySelectorAll('.flip-char .inner-char');
    gsap.from(flipChars, {
      rotateX: -90,
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.05,
      ease: "back.out(1.7)",
      delay: 0.5
    });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: wrapper,
        start: 'top top',
        end: '+=400%',
        scrub: 1,
        pin: true,
        invalidateOnRefresh: true,
        snap: {
          snapTo: [0, 0.3, 0.65, 1],
          duration: { min: 0.1, max: 0.3 },
          delay: 0,
          ease: "power2.out"
        }
      }
    });

    const phases = [
        { label: 'Virtual Pacing Academy', color: '#3B3CFF' },
        { label: 'The Problem', color: '#3B3CFF' },
        { label: 'The Solution', color: '#FFE000' },
        { label: 'The Outcome', color: '#34d399' }
    ];

    const phaseLabel = document.querySelector('#journey-phase-label');

    // Section 0: Hero -> Phase 1: Problem
    tl.to('#phase-hero', { opacity: 0, y: -40, duration: 1 }, 0);
    tl.to('#visual-hero', { opacity: 0, scale: 1.1, duration: 1 }, 0);
    
    tl.to('#phase-problem', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[1].label;
            gsap.to(phaseLabel, { color: phases[1].color, duration: 0.3 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[0].label;
            gsap.to(phaseLabel, { color: phases[0].color, duration: 0.3 });
        }
    }}, 0);
    tl.to('#visual-problem', { opacity: 1, scale: 1, duration: 1 }, 0);

    // Phase 1 -> Phase 2: Solution
    tl.to('#phase-problem', { opacity: 0, y: -40, duration: 1 }, 1.5);
    tl.to('#visual-problem', { opacity: 0, scale: 0.8, duration: 1 }, 1.5);
    
    tl.to('#phase-solution', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[2].label;
            gsap.to(phaseLabel, { color: phases[2].color, duration: 0.3 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[1].label;
            gsap.to(phaseLabel, { color: phases[1].color, duration: 0.3 });
        }
    }}, 1.5);
    tl.to('#visual-solution', { opacity: 1, scale: 1, duration: 1 }, 1.5);

    // Phase 2 -> Phase 3: Outcome
    tl.to('#phase-solution', { opacity: 0, y: -40, duration: 1 }, 3);
    tl.to('#visual-solution', { opacity: 0, scale: 0.8, duration: 1 }, 3);

    tl.to('#phase-outcome', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[3].label;
            gsap.to(phaseLabel, { color: phases[3].color, duration: 0.3 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[2].label;
            gsap.to(phaseLabel, { color: phases[2].color, duration: 0.3 });
        }
    }}, 3);
    tl.to('#visual-outcome', { opacity: 1, scale: 1, duration: 1 }, 3);

    tl.to({}, { duration: 1 });
  });
</script>

<style>
  .narrative-phase, .visual-phase {
    will-change: opacity, transform;
  }
  spline-viewer {
    width: 100%;
    height: 100%;
  }
  .inner-char {
    display: inline-block;
    transform-origin: center bottom;
  }
</style>
