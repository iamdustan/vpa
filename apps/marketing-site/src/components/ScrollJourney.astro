---
---

<div class="relative w-full bg-background" id="scrolly-narrative-container">
  {/* The Main Segmented Layout */}
  <div class="sticky top-0 h-screen w-full flex flex-col overflow-hidden">
    
    {/* Top Content Area: Split Left/Right */}
    <div class="flex-1 flex flex-col lg:flex-row w-full max-w-[1600px] mx-auto px-6 lg:px-12 pt-24 pb-12 gap-12 lg:gap-24">
      
      {/* Left Segment: Narrative Pitch */}
      <div class="flex-1 flex flex-col justify-center relative z-10">
        <div class="space-y-12 relative h-[400px]">
          
          <div class="narrative-text absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="pitch-1">
            <h2 class="text-xs font-black uppercase tracking-[0.4em] text-brand-blue mb-4">The Problem</h2>
            <h3 class="text-4xl md:text-6xl font-black text-white leading-[0.9] uppercase tracking-tighter">
              Education <br/><span class="text-gradient">is broken.</span>
            </h3>
            <p class="mt-8 text-xl text-white/50 font-medium max-w-md leading-relaxed">
              Traditional schools cost $30k and take a year. Standard online courses leave you isolated. 
            </p>
          </div>

          <div class="narrative-text absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="pitch-2">
            <h2 class="text-xs font-black uppercase tracking-[0.4em] text-brand-orange mb-4">The Solution</h2>
            <h3 class="text-4xl md:text-6xl font-black text-white leading-[0.9] uppercase tracking-tighter">
              Mentorship <br/><span class="text-brand-orange">is the key.</span>
            </h3>
            <p class="mt-8 text-xl text-white/50 font-medium max-w-md leading-relaxed">
              We pair you with industry veterans who coach you through every single step of your transition.
            </p>
          </div>

          <div class="narrative-text absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="pitch-3">
            <h2 class="text-xs font-black uppercase tracking-[0.4em] text-emerald-400 mb-4">The Outcome</h2>
            <h3 class="text-4xl md:text-6xl font-black text-white leading-[0.9] uppercase tracking-tighter">
              Land the <br/><span class="text-emerald-400">Dream Job.</span>
            </h3>
            <p class="mt-8 text-xl text-white/50 font-medium max-w-md leading-relaxed">
              From the first rhythm to your first day in the OR, we guide you to a career with purpose.
            </p>
          </div>

        </div>
      </div>

      {/* Right Segment: Interactive Animations/Cards */}
      <div class="flex-1 relative flex items-center justify-center">
        <div class="w-full aspect-square max-w-lg glass-card relative overflow-hidden flex items-center justify-center border-white/5 shadow-2xl shadow-black/50">
          
          {/* Card 1: Problem Visual */}
          <div class="visual-element absolute inset-0 flex items-center justify-center opacity-0" id="visual-1">
            <div class="relative w-32 h-32 border-2 border-white/10 rounded-full flex items-center justify-center">
                <div class="w-16 h-px bg-white/20 rotate-45"></div>
                <div class="w-16 h-px bg-white/20 -rotate-45"></div>
                <div class="absolute -top-4 text-[10px] font-black uppercase tracking-widest text-white/20">System Error</div>
            </div>
            <div class="absolute inset-0 bg-brand-blue/5 animate-pulse"></div>
          </div>

          {/* Card 2: Partnership Visual */}
          <div class="visual-element absolute inset-0 flex items-center justify-center opacity-0" id="visual-2">
             <div class="flex gap-4">
                <div class="w-24 h-24 rounded-2xl bg-brand-orange/20 border border-brand-orange/40 flex items-center justify-center font-black text-brand-orange">YOU</div>
                <div class="flex items-center text-white/20">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </div>
                <div class="w-24 h-24 rounded-2xl bg-brand-blue/20 border border-brand-blue/40 flex items-center justify-center font-black text-brand-blue text-center text-xs">VETERAN MENTOR</div>
             </div>
          </div>

          {/* Card 3: Success Visual */}
          <div class="visual-element absolute inset-0 flex items-center justify-center opacity-0" id="visual-3">
             <div class="text-center">
                <div class="text-6xl mb-4">🏆</div>
                <div class="text-xs font-black uppercase tracking-[0.3em] text-emerald-400">Cohort Complete</div>
             </div>
             <div class="absolute inset-0 bg-emerald-400/5"></div>
          </div>

        </div>
      </div>

    </div>

    {/* Bottom Segment: Constant Call to Action */}
    <div class="h-24 lg:h-32 border-t border-white/5 bg-surface/40 backdrop-blur-xl px-6 lg:px-12">
      <div class="h-full max-w-[1600px] mx-auto flex items-center justify-between">
        <div class="hidden md:flex flex-col">
            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30">Current Phase</span>
            <span class="text-sm font-black uppercase text-brand-blue" id="current-phase-label">Investigation</span>
        </div>

        <div class="flex gap-4 w-full md:w-auto">
            <a href="/curriculum" class="flex-1 md:flex-none px-8 py-3 rounded-full border border-white/10 text-[10px] font-black uppercase tracking-widest hover:bg-white/5 transition-all text-center">Get More Info</a>
            <a href="/apply" class="flex-1 md:flex-none px-8 py-3 rounded-full bg-brand-blue text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue/90 transition-all text-center shadow-lg shadow-brand-blue/20">Register for Cohort</a>
        </div>
      </div>
    </div>

  </div>

  {/* Scroll Spacer */}
  <div class="h-[400vh]"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const container = document.querySelector('#scrolly-narrative-container');
    if (!container) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        pin: true,
        invalidateOnRefresh: true,
      }
    });

    const phases = [
        { label: 'The Problem', color: '#2223D3' },
        { label: 'The Solution', color: '#E93313' },
        { label: 'The Outcome', color: '#34d399' }
    ];

    const phaseLabel = document.querySelector('#current-phase-label');

    // Section 1: Problem (Already visible at start, but let's animate in)
    tl.to('#pitch-1', { opacity: 1, pointerEvents: 'auto', duration: 1 }, 0);
    tl.to('#visual-1', { opacity: 1, scale: 1, duration: 1 }, 0);
    
    // Transition to Phase 2: Solution
    tl.to('#pitch-1', { opacity: 0, y: -20, duration: 1 }, 1.5);
    tl.to('#visual-1', { opacity: 0, scale: 0.9, duration: 1 }, 1.5);
    
    tl.to('#pitch-2', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[1].label;
            gsap.to(phaseLabel, { color: phases[1].color, duration: 0.3 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[0].label;
            gsap.to(phaseLabel, { color: phases[0].color, duration: 0.3 });
        }
    }}, 2);
    tl.to('#visual-2', { opacity: 1, scale: 1, duration: 1 }, 2);

    // Transition to Phase 3: Outcome
    tl.to('#pitch-2', { opacity: 0, y: -20, duration: 1 }, 3.5);
    tl.to('#visual-2', { opacity: 0, scale: 0.9, duration: 1 }, 3.5);

    tl.to('#pitch-3', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[2].label;
            gsap.to(phaseLabel, { color: phases[2].color, duration: 0.3 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[1].label;
            gsap.to(phaseLabel, { color: phases[1].color, duration: 0.3 });
        }
    }}, 4);
    tl.to('#visual-3', { opacity: 1, scale: 1, duration: 1 }, 4);

  });
</script>

<style>
  .narrative-text, .visual-element {
    will-change: opacity, transform;
  }
</style>
