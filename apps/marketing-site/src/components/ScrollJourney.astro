---
---

<div class="relative w-full bg-page-bg" id="scrolly-narrative-container">
  <div class="sticky top-0 h-screen w-full flex items-center justify-center p-6 lg:p-12 overflow-hidden">
    
    {/* The Central Rounded Cube Card */}
    <div class="w-full max-w-[1600px] aspect-[16/10] max-h-[90vh] bg-background rounded-[40px] overflow-hidden flex flex-col relative shadow-2xl shadow-black/50 border border-white/5">
      
      {/* Top Segment: Narrative & Visuals */}
      <div class="flex-1 flex flex-col lg:flex-row min-h-0">
        
        {/* Left Segment: Narrative Pitch */}
        <div class="w-full lg:w-[45%] p-12 lg:p-20 flex flex-col justify-center border-b lg:border-b-0 lg:border-r border-white/5 relative overflow-hidden">
          <div class="relative h-full w-full">
            
            <div class="narrative-text absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="pitch-1">
              <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6">The Problem</h2>
              <h3 class="text-5xl md:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Education <br/><span class="text-gradient">is broken.</span>
              </h3>
              <p class="mt-8 text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                Traditional schools cost $30k and take a year. Standard online courses leave you isolated. 
              </p>
            </div>

            <div class="narrative-text absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="pitch-2">
              <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-brand-orange mb-6">The Solution</h2>
              <h3 class="text-5xl md:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Mentorship <br/><span class="text-brand-orange">is the key.</span>
              </h3>
              <p class="mt-8 text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                We pair you with industry veterans who coach you through every single step of your transition.
              </p>
            </div>

            <div class="narrative-text absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="pitch-3">
              <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-400 mb-6">The Outcome</h2>
              <h3 class="text-5xl md:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Land the <br/><span class="text-emerald-400">Dream Job.</span>
              </h3>
              <p class="mt-8 text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                From the first rhythm to your first day in the OR, we guide you to a career with purpose.
              </p>
            </div>

          </div>
        </div>

        {/* Right Segment: Dynamic Animations */}
        <div class="flex-1 relative bg-surface/10 flex items-center justify-center p-20">
            {/* Visual containment for animations */}
            <div class="w-full h-full relative">
                
                {/* Visual 1: Problem */}
                <div class="visual-element absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-1">
                    <div class="w-48 h-48 rounded-full border border-white/5 flex items-center justify-center relative">
                        <div class="absolute inset-0 border border-brand-blue/20 rounded-full animate-ping"></div>
                        <div class="w-24 h-px bg-white/20 rotate-45"></div>
                        <div class="w-24 h-px bg-white/20 -rotate-45"></div>
                    </div>
                </div>

                {/* Visual 2: Solution */}
                <div class="visual-element absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-2">
                    <div class="flex items-center gap-12">
                        <div class="w-24 h-24 rounded-3xl bg-brand-orange/10 border border-brand-orange/30 flex items-center justify-center font-black text-brand-orange uppercase text-xs">Student</div>
                        <div class="w-12 h-px bg-white/10 relative">
                            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-brand-orange"></div>
                        </div>
                        <div class="w-32 h-32 rounded-full border-2 border-brand-blue border-dashed animate-[spin_10s_linear_infinite] p-2">
                            <div class="w-full h-full rounded-full bg-brand-blue/20 flex items-center justify-center font-black text-white uppercase text-[10px] text-center">Mentor</div>
                        </div>
                    </div>
                </div>

                {/* Visual 3: Outcome */}
                <div class="visual-element absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-3">
                    <div class="text-center relative">
                        <div class="text-9xl mb-8 opacity-20 blur-sm absolute inset-0 translate-y-4">🏆</div>
                        <div class="text-9xl relative">🏆</div>
                        <div class="mt-8 text-xs font-black uppercase tracking-[0.5em] text-emerald-400">Success Attained</div>
                    </div>
                </div>

            </div>
        </div>

      </div>

      {/* Bottom Segment: Constant Call to Action */}
      <div class="h-24 lg:h-32 border-t border-white/5 bg-surface/20 px-12 lg:px-20">
        <div class="h-full w-full mx-auto flex items-center justify-between">
          <div class="flex flex-col">
              <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30">Program Path</span>
              <span class="text-sm font-black uppercase text-brand-blue transition-colors duration-500" id="current-phase-label">Phase 01: The Problem</span>
          </div>

          <div class="flex gap-8 items-center">
              <a href="/curriculum" class="text-[10px] font-black uppercase tracking-widest text-white/50 hover:text-white transition-colors">Get More Info</a>
              <a href="/apply" class="px-10 py-4 rounded-full bg-brand-blue text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue/90 transition-all shadow-xl shadow-brand-blue/20">Register for Cohort</a>
          </div>
        </div>
      </div>

    </div>
  </div>

  {/* Scroll Spacer */}
  <div class="h-[400vh]"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const container = document.querySelector('#scrolly-narrative-container');
    if (!container) return;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        pin: true,
        invalidateOnRefresh: true,
      }
    });

    const phases = [
        { label: 'Phase 01: The Problem', color: '#2223D3' },
        { label: 'Phase 02: The Solution', color: '#E93313' },
        { label: 'Phase 03: The Outcome', color: '#34d399' }
    ];

    const phaseLabel = document.querySelector('#current-phase-label');

    // Section 1: Problem
    tl.to('#pitch-1', { opacity: 1, pointerEvents: 'auto', duration: 1 }, 0);
    tl.to('#visual-1', { opacity: 1, scale: 1, duration: 1 }, 0);
    
    // Transition to Phase 2: Solution
    tl.to('#pitch-1', { opacity: 0, y: -40, duration: 1 }, 1.5);
    tl.to('#visual-1', { opacity: 0, scale: 0.8, duration: 1 }, 1.5);
    
    tl.to('#pitch-2', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[1].label;
            gsap.to(phaseLabel, { color: phases[1].color, duration: 0.5 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[0].label;
            gsap.to(phaseLabel, { color: phases[0].color, duration: 0.5 });
        }
    }}, 2);
    tl.to('#visual-2', { opacity: 1, scale: 1, duration: 1 }, 2);

    // Transition to Phase 3: Outcome
    tl.to('#pitch-2', { opacity: 0, y: -40, duration: 1 }, 3.5);
    tl.to('#visual-2', { opacity: 0, scale: 0.8, duration: 1 }, 3.5);

    tl.to('#pitch-3', { opacity: 1, pointerEvents: 'auto', y: 0, duration: 1, onStart: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[2].label;
            gsap.to(phaseLabel, { color: phases[2].color, duration: 0.5 });
        }
    }, onReverseComplete: () => {
        if (phaseLabel) {
            phaseLabel.textContent = phases[1].label;
            gsap.to(phaseLabel, { color: phases[1].color, duration: 0.5 });
        }
    }}, 4);
    tl.to('#visual-3', { opacity: 1, scale: 1, duration: 1 }, 4);

  });
</script>

<style>
  .narrative-text, .visual-element {
    will-change: opacity, transform;
  }
</style>
