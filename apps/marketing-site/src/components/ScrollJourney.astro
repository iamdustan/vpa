---
interface Props {
  sceneUrl: string;
  heroTitle: string;
  heroSubtitle: string;
}

const { sceneUrl, heroTitle, heroSubtitle } = Astro.props;

// Helper to split text for character animations
const splitText = (text: string) => {
  return text.split('').map((char) => ({
    char: char === ' ' ? '\u00A0' : char,
    isSpace: char === ' '
  }));
};

const titleParts = heroTitle.split(' ');
const firstWord = `${titleParts[0]} ${titleParts[1]}`;
const remainingTitle = titleParts.slice(2).join(' ');
const titleChars = splitText(remainingTitle);
---

<div class="relative w-full bg-page-bg" id="scrolly-journey-wrapper">
  <div id="scrolly-journey-card-container" class="h-screen w-full flex items-end justify-center p-4 md:p-6 lg:p-10 overflow-hidden">
    
    <div class="w-full max-w-[1600px] h-[85vh] lg:h-[88vh] bg-background rounded-3xl lg:rounded-[40px] overflow-hidden flex flex-col relative shadow-2xl shadow-black/50 border border-white/5">
      
      <div class="flex-1 flex flex-col-reverse lg:flex-row min-h-0">
        
        <div class="w-full h-1/2 lg:h-full lg:w-[45%] p-8 md:p-12 lg:p-24 flex flex-col justify-center border-t lg:border-t-0 lg:border-r border-white/5 relative overflow-hidden">
          <div class="relative h-full w-full">
            
            {/* Phase 0: Hero */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-100" id="phase-hero">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-green mb-6 lg:mb-8">Virtual Pacing Academy</h2>
              <h1 class="text-3xl md:text-5xl lg:text-7xl font-black tracking-tighter text-white leading-[0.9] text-gradient uppercase flex flex-wrap">
                <span class="mr-[0.2em]">{firstWord}</span>
                <span class="flex flip-container">
                  {titleChars.map(({ char, isSpace }) => (
                    <span class={`flip-char inline-block ${isSpace ? 'mr-[0.2em]' : ''}`} style="perspective: 1000px;">
                      <span class="inline-block inner-char">{char}</span>
                    </span>
                  ))}
                </span>
              </h1>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/50 font-medium leading-relaxed max-w-sm">
                {heroSubtitle}
              </p>
            </div>

            {/* Phase 1: Career Impact (Why) */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-why">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6 lg:mb-8">Career Impact</h2>
              <h3 class="text-3xl md:text-5xl lg:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Land the <br/><span class="text-brand-blue">Dream Job.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                From the first rhythm to your first day in the OR, we guide you to a career with purpose, impact, and security.
              </p>
            </div>

            {/* Phase 2: The Experience (How) */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-how">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-yellow mb-6 lg:mb-8">The Experience</h2>
              <h3 class="text-3xl md:text-5xl lg:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Mentorship <br/><span class="text-brand-yellow">is the key.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                Skip the "content drops." We pair you with industry veterans who coach you through every step of your transition.
              </p>
            </div>

            {/* Phase 3: Next Steps (CTA) */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-cta">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-green mb-6 lg:mb-8">Next Steps</h2>
              <h3 class="text-3xl md:text-5xl lg:text-7xl font-black text-white leading-[0.9] uppercase tracking-tighter">
                Start your <br/><span class="text-brand-green">Journey Today.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-white/40 font-medium max-w-sm leading-relaxed">
                The medical device industry is waiting. Take the first step toward your new career.
              </p>
              <div class="mt-10 flex flex-wrap gap-4">
                  <a href={`${import.meta.env.BASE_URL}apply`} class="px-8 py-4 rounded-full bg-brand-green text-xs font-black uppercase tracking-widest hover:bg-brand-green/90 transition-all shadow-xl shadow-brand-green/20 text-white">Apply Now</a>
              </div>
            </div>

          </div>
        </div>

        <div class="flex-1 relative bg-surface/10 flex items-center justify-center overflow-hidden">
            <div class="visual-phase absolute inset-0 opacity-100" id="visual-hero">
                <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.59/build/spline-viewer.js"></script>
                <spline-viewer 
                    url={sceneUrl} 
                    events-target="global" 
                    loading-library="lazy"
                    class="w-full h-full"
                ></spline-viewer>
            </div>

            <div class="absolute inset-0 flex items-center justify-center p-6 lg:p-20">
                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-why">
                    <div class="text-center relative">
                        <div class="text-7xl md:text-9xl mb-4 md:mb-8 opacity-20 blur-sm absolute inset-0 translate-y-4">🏆</div>
                        <div class="text-7xl md:text-9xl relative">🏆</div>
                        <div class="mt-4 md:mt-8 text-[10px] md:text-xs font-black uppercase tracking-[0.5em] text-brand-blue">Success Attained</div>
                    </div>
                </div>

                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-how">
                    <div class="flex items-center gap-4 md:gap-12">
                        <div class="w-16 h-16 md:w-24 md:h-24 rounded-2xl md:rounded-3xl bg-brand-yellow/10 border border-brand-yellow/30 flex items-center justify-center font-black text-brand-yellow uppercase text-[8px] md:text-xs">Student</div>
                        <div class="w-6 md:w-12 h-px bg-white/10 relative">
                            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-brand-yellow"></div>
                        </div>
                        <div class="w-24 h-24 md:w-32 md:h-32 rounded-full border-2 border-brand-blue border-dashed animate-[spin_10s_linear_infinite] p-2">
                            <div class="w-full h-full rounded-full bg-brand-blue/20 flex items-center justify-center font-black text-white uppercase text-[8px] md:text-[10px] text-center">Mentor</div>
                        </div>
                    </div>
                </div>

                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-cta">
                    <div class="w-32 h-32 md:w-48 md:h-48 rounded-full border border-white/5 flex items-center justify-center relative">
                        <div class="absolute inset-0 border border-brand-green/20 rounded-full animate-ping"></div>
                        <div class="w-16 md:w-24 h-px bg-white/20 rotate-45"></div>
                        <div class="w-16 md:w-24 h-px bg-white/20 -rotate-45"></div>
                    </div>
                </div>
            </div>
        </div>

      </div>

      <div class="h-auto lg:h-32 border-t border-white/5 bg-surface/20 px-6 py-4 lg:py-0 lg:px-20">
        <div class="h-full w-full mx-auto flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
          <div class="flex flex-col text-center md:text-left w-full md:w-auto">
              <span class="text-[8px] lg:text-[10px] font-black uppercase tracking-[0.2em] text-white/30">Journey Phase</span>
              <span class="text-xs lg:text-sm font-black uppercase text-brand-green" id="journey-phase-label">The Foundation</span>          </div>

          <div class="flex flex-col md:flex-row gap-4 lg:gap-8 items-center w-full md:w-auto">
              <a href={`${import.meta.env.BASE_URL}curriculum`} class="text-[8px] lg:text-[10px] font-black uppercase tracking-widest text-white/70 hover:text-white transition-colors w-full md:w-auto text-center border border-white/10 md:border-none rounded-full px-6 py-3 md:p-0">Explore Curriculum</a>
              <a href={`${import.meta.env.BASE_URL}apply`} class="w-full md:w-auto px-10 py-3 lg:py-4 rounded-full bg-brand-blue text-[8px] lg:text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue/90 transition-all shadow-xl shadow-brand-blue/20 text-center">Apply Now</a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="h-[500vh] pointer-events-none"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const wrapper = document.querySelector('#scrolly-journey-wrapper');
    const cardContainer = document.querySelector('#scrolly-journey-card-container');
    if (!wrapper || !cardContainer) return;

    // Initial Flip Animation for Hero Title
    const flipChars = document.querySelectorAll('.flip-char .inner-char');
    gsap.from(flipChars, {
      rotateX: -90,
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.05,
      ease: "back.out(1.7)",
      delay: 0.5
    });

    const phases = [
        { id: 'hero', label: 'THE FOUNDATION', color: '#52cf95' },
        { id: 'why', label: 'CAREER IMPACT', color: '#3B3CFF' },
        { id: 'how', label: 'THE EXPERIENCE', color: '#FFE000' },
        { id: 'cta', label: 'NEXT STEPS', color: '#52cf95' }
    ];

    const phaseLabel = document.querySelector('#journey-phase-label');
    let currentPhaseIndex = 0;

    const updatePhaseLabel = (index) => {
        const { label, color } = phases[index];
        
        phaseLabel.innerHTML = '';
        label.split('').forEach((char) => {
            const span = document.createElement('span');
            span.className = 'flip-char inline-block';
            if (char === ' ') {
                span.classList.add('mr-[0.2em]');
                span.innerHTML = '<span class="inline-block inner-char">&nbsp;</span>';
            } else {
                span.innerHTML = `<span class="inline-block inner-char">${char}</span>`;
            }
            span.style.perspective = '1000px';
            const inner = span.querySelector('.inner-char');
            inner.style.color = color;
            phaseLabel.appendChild(span);
        });

        gsap.fromTo(phaseLabel.querySelectorAll('.inner-char'), 
            { rotateX: -90, opacity: 0, y: 10 },
            { 
                rotateX: 0, 
                opacity: 1, 
                y: 0, 
                duration: 0.4, 
                stagger: 0.03, 
                ease: "back.out(1.7)",
                overwrite: true 
            }
        );
    };

    const goToPhase = (index) => {
        if (index === currentPhaseIndex) return;
        
        const prev = phases[currentPhaseIndex];
        const next = phases[index];
        currentPhaseIndex = index;

        // Exit Previous
        gsap.to(`#phase-${prev.id}`, { opacity: 0, y: -40, duration: 0.6, pointerEvents: 'none', overwrite: 'auto' });
        gsap.to(`#visual-${prev.id}`, { opacity: 0, scale: 0.85, duration: 0.6, overwrite: 'auto' });

        // Enter Next
        gsap.to(`#phase-${next.id}`, { opacity: 1, y: 0, duration: 0.8, pointerEvents: 'auto', delay: 0.1, overwrite: 'auto' });
        gsap.to(`#visual-${next.id}`, { opacity: 1, scale: 1, duration: 0.8, delay: 0.1, overwrite: 'auto' });

        updatePhaseLabel(index);
    };

    // Initialize the first label with animation characters
    if (phaseLabel) {
        const { label, color } = phases[0];
        phaseLabel.innerHTML = '';
        label.split('').forEach((char) => {
            const span = document.createElement('span');
            span.className = 'flip-char inline-block';
            if (char === ' ') {
                span.classList.add('mr-[0.2em]');
                span.innerHTML = '<span class="inline-block inner-char">&nbsp;</span>';
            } else {
                span.innerHTML = `<span class="inline-block inner-char">${char}</span>`;
            }
            span.style.perspective = '1000px';
            const inner = span.querySelector('.inner-char');
            inner.style.color = color;
            phaseLabel.appendChild(span);
        });
    }

    ScrollTrigger.create({
        trigger: wrapper,
        start: 'top top',
        end: '+=400%',
        pin: true,
        snap: {
            snapTo: [0, 0.33, 0.66, 1],
            duration: { min: 0.2, max: 0.5 },
            delay: 0.1,
            ease: "power2.inOut"
        },
        onUpdate: (self) => {
            const p = self.progress;
            let newIndex = 0;
            if (p > 0.83) newIndex = 3;
            else if (p > 0.5) newIndex = 2;
            else if (p > 0.16) newIndex = 1;
            
            if (newIndex !== currentPhaseIndex) {
                goToPhase(newIndex);
            }
        }
    });
  });
</script>

<style>
  .narrative-phase, .visual-phase {
    will-change: opacity, transform;
  }
  spline-viewer {
    width: 100%;
    height: 100%;
  }
  .inner-char {
    display: inline-block;
    transform-origin: center bottom;
  }
</style>
