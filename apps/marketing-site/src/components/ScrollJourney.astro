---
---

<div class="relative w-full overflow-hidden bg-slate-950" id="narrative-container">
  {/* The Thread (SVG) */}
  <svg class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 pointer-events-none z-0" overflow="visible">
    <path id="mentorship-thread" d="" fill="none" stroke="url(#thread-gradient)" stroke-width="2" stroke-linecap="round" />
    <defs>
      <linearGradient id="thread-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#6366f1" stop-opacity="0" />
        <stop offset="20%" stop-color="#6366f1" stop-opacity="1" />
        <stop offset="80%" stop-color="#22d3ee" stop-opacity="1" />
        <stop offset="100%" stop-color="#22d3ee" stop-opacity="0" />
      </linearGradient>
    </defs>
  </svg>

  {/* Pinned Content Section */}
  <div id="narrative-target" class="h-screen flex flex-col justify-center items-center px-6">
    <div class="relative z-10 w-full max-w-5xl text-center space-y-24">
      
      {/* Section 2: The Problem */}
      <div class="narrative-step opacity-0" id="step-problem">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white leading-tight tracking-tight">
          Asynchronous online learning <span class="text-indigo-400">is inefficient.</span>
        </h2>
        <p class="mt-8 text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
          Brick-and-mortar schools cost $30,000+ and a year of your life. 
          Standard online courses leave you isolated. 
          <span class="block mt-4 text-white font-semibold italic">It just doesn't work well.</span>
        </p>
      </div>

      {/* Section 3: The Turning Point */}
      <div class="narrative-step absolute inset-0 flex flex-col justify-center items-center opacity-0" id="step-mentorship">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white leading-tight tracking-tight">
          Mentorship <span class="text-cyan-400 font-black italic">is the key.</span>
        </h2>
        <p class="mt-8 text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
          Virtual learning provides flexibility, but <span class="text-white underline decoration-cyan-500/50">partnership</span> provides the career. 
          Our veteran mentors coach you every single step of the way.
        </p>
      </div>

      {/* Section 4: The Promise */}
      <div class="narrative-step absolute inset-0 flex flex-col justify-center items-center opacity-0" id="step-partnership">
        <h2 class="text-4xl md:text-6xl font-black text-white leading-none tracking-tighter uppercase">
          This is not a <span class="bg-gradient-to-r from-indigo-500 to-cyan-500 bg-clip-text text-transparent">content drop.</span>
        </h2>
        <p class="mt-8 text-xl md:text-2xl text-slate-300 max-w-3xl mx-auto leading-relaxed font-medium">
          We only succeed when you succeed. 
          From the first rhythm to your first day in the OR, we go on the journey with you.
        </p>
        <div class="mt-12 flex justify-center gap-6">
           <div class="flex items-center gap-2 text-indigo-400">
             <span class="h-2 w-2 rounded-full bg-indigo-400 animate-pulse"></span>
             <span class="text-sm font-bold tracking-widest uppercase">1-on-1 Coaching</span>
           </div>
           <div class="flex items-center gap-2 text-cyan-400">
             <span class="h-2 w-2 rounded-full bg-cyan-400 animate-pulse"></span>
             <span class="text-sm font-bold tracking-widest uppercase">Lifetime Network</span>
           </div>
        </div>
      </div>

    </div>
  </div>

  {/* Scroll Spacer */}
  <div class="h-[500vh]"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('load', () => {
    const container = document.querySelector('#narrative-container');
    const target = document.querySelector('#narrative-target');
    const thread = document.querySelector('#mentorship-thread');
    
    if (!container || !target || !thread) return;

    // Set initial thread path
    const updateThreadPath = () => {
      const h = container.getBoundingClientRect().height;
      thread.setAttribute('d', `M 0 0 L 0 ${h}`);
    };
    updateThreadPath();
    window.addEventListener('resize', updateThreadPath);

    // Narrative Timeline
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        pin: '#narrative-target',
        invalidateOnRefresh: true,
      }
    });

    // Animate the thread drawing
    const threadLength = thread.getTotalLength();
    gsap.set(thread, { strokeDasharray: threadLength, strokeDashoffset: threadLength });
    
    tl.to(thread, { strokeDashoffset: 0, duration: 10, ease: 'none' }, 0);

    // Step: Problem
    tl.to('#step-problem', { opacity: 1, y: -20, duration: 2 }, 1);
    tl.to('#step-problem', { opacity: 0, y: -50, duration: 1.5, delay: 1 });

    // Step: Mentorship
    tl.to('#step-mentorship', { opacity: 1, y: -20, duration: 2 });
    tl.to('#step-mentorship', { opacity: 0, y: -50, duration: 1.5, delay: 1 });

    // Step: Partnership
    tl.to('#step-partnership', { opacity: 1, scale: 1.05, duration: 3 });
    
    // Background Color Shifts
    tl.to('#narrative-container', { backgroundColor: '#0f172a', duration: 3 }, 2);
    tl.to('#narrative-container', { backgroundColor: '#020617', duration: 3 }, 5);
  });
</script>

<style>
  .narrative-step {
    transition: filter 0.5s ease-out;
  }
</style>
