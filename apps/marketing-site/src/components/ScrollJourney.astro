---
---

<div class="relative w-full" id="journey-container">
  {/* The pinned element needs to be the one that stays in view */}
  <div id="scrolly-target" class="h-screen flex flex-col justify-center items-center overflow-hidden bg-slate-950">
    
    {/* Background Bridge Element */}
    <div id="bridge-visual" class="absolute w-[200%] h-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-cyan-500 opacity-0 blur-md -rotate-12 scale-x-50"></div>
    
    {/* Story Sections */}
    <div class="relative z-10 w-full max-w-4xl px-6 text-center">
      <div class="story-step invisible" id="step-1">
        <h3 class="text-4xl md:text-7xl font-black text-white mb-6 tracking-tighter">THE DISCONNECT</h3>
        <p class="text-xl md:text-2xl text-slate-400 font-medium">You're in a job that feels flat. You have the ambition, but the barrier to MedTech feels insurmountable.</p>
      </div>
      
      <div class="story-step invisible absolute inset-0 flex flex-col justify-center items-center px-6" id="step-2">
        <h3 class="text-4xl md:text-7xl font-black text-white mb-6 tracking-tighter uppercase italic">The Bridge</h3>
        <p class="text-xl md:text-2xl text-slate-400 font-medium">VPA isn't a course. It's an direct line to the industry. 1-on-1 mentorship from the experts who built the field.</p>
      </div>
      
      <div class="story-step invisible absolute inset-0 flex flex-col justify-center items-center px-6" id="step-3">
        <h3 class="text-4xl md:text-7xl font-black bg-gradient-to-br from-white to-slate-400 bg-clip-text text-transparent mb-6 tracking-tighter uppercase">Clinical Mastery</h3>
        <p class="text-xl md:text-2xl text-slate-400 font-medium">Transform from an outsider to a specialist. Lifesaving technology. A network that opens every door.</p>
      </div>
    </div>
  </div>
  
  {/* The total scroll length is determined by the height of the container */}
  <div class="h-[400vh]"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Use window load to ensure all styles/elements are ready
  window.addEventListener('load', () => {
    const container = document.querySelector('#journey-container');
    const scrollyTarget = document.querySelector('#scrolly-target');
    
    if (!container || !scrollyTarget) return;

    // Create the timeline
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.5, // Smoother scrubbing
        pin: '#scrolly-target', // Explicitly pin the target
        anticipatePin: 1,
        invalidateOnRefresh: true,
      }
    });

    // Step 1: Fade in
    tl.fromTo('#step-1', 
      { autoAlpha: 0, y: 50 }, 
      { autoAlpha: 1, y: 0, duration: 1 }
    );
    tl.fromTo('#bridge-visual', 
      { opacity: 0, scaleX: 0.5, rotate: -12 }, 
      { opacity: 0.3, scaleX: 1, rotate: -6, duration: 1.5 }, 
      "<"
    );
    
    // Step 1: Fade out
    tl.to('#step-1', { autoAlpha: 0, y: -50, duration: 1, delay: 0.5 });

    // Step 2: Fade in
    tl.fromTo('#step-2', 
      { autoAlpha: 0, y: 50 }, 
      { autoAlpha: 1, y: 0, duration: 1 }
    );
    tl.to('#bridge-visual', { opacity: 0.6, scaleX: 1.5, rotate: 0, duration: 1.5 }, "<");
    
    // Step 2: Fade out
    tl.to('#step-2', { autoAlpha: 0, y: -50, duration: 1, delay: 0.5 });

    // Step 3: Fade in
    tl.fromTo('#step-3', 
      { autoAlpha: 0, y: 50 }, 
      { autoAlpha: 1, y: 0, duration: 1 }
    );
    tl.to('#bridge-visual', { 
      opacity: 1, 
      scaleX: 2.5, 
      rotate: 6, 
      filter: 'blur(0px)', 
      height: '4px',
      duration: 1.5 
    }, "<");
    
    // Final hold
    tl.to({}, { duration: 1 });
  });
</script>

<style>
  /* Use autoAlpha (visibility + opacity) to prevent flashes */
  .invisible {
    visibility: hidden;
    opacity: 0;
  }
</style>
