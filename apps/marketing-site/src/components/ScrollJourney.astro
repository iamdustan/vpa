---
interface Props {
  heroTitle: string;
  heroSubtitle: string;
}

const { heroTitle, heroSubtitle } = Astro.props;

// Helper to split text for character animations
const splitText = (text: string) => {
  return text.split('').map((char) => ({
    char: char === ' ' ? '\u00A0' : char,
    isSpace: char === ' '
  }));
};

const titleParts = heroTitle.split(' ');
const firstLine = `${titleParts[0]} ${titleParts[1]}`;
const secondLine = titleParts.slice(2).join(' ');
const line1Chars = splitText(firstLine);
const line2Chars = splitText(secondLine);
---

<div class="relative w-full bg-page-bg overflow-hidden" id="scrolly-journey-wrapper">
  <div id="scrolly-journey-card-container" class="h-screen w-full flex items-end justify-center p-4 md:p-6 lg:p-10 overflow-hidden">
    
    <div class="w-full max-w-[1600px] h-[85vh] lg:h-[88vh] bg-background rounded-3xl lg:rounded-[40px] overflow-hidden flex flex-col relative shadow-2xl shadow-black/50 border border-primary/5">
      
      <div class="flex-1 flex flex-col-reverse lg:flex-row min-h-0">
        
        <div class="w-full h-1/2 lg:h-full lg:w-[55%] p-8 md:p-12 lg:p-20 xl:p-24 flex flex-col justify-center border-t lg:border-t-0 lg:border-r border-primary/5 relative overflow-hidden">
          <div class="relative h-full w-full">
            
            {/* Phase 0: Foundation */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-100" id="phase-hero">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-green mb-6 lg:mb-8">Virtual Pacing Academy</h2>
              <h1 class="text-3xl md:text-5xl lg:text-6xl xl:text-7xl font-black tracking-tighter text-primary leading-[0.9] text-gradient flex flex-col">
                <span class="flex flip-container">
                  {line1Chars.map(({ char, isSpace }) => (
                    <span class={`flip-char inline-block ${isSpace ? 'mr-[0.2em]' : ''}`} style="perspective: 1000px;">
                      <span class="inline-block inner-char">{char}</span>
                    </span>
                  ))}
                </span>
                <span class="flex flip-container">
                  {line2Chars.map(({ char, isSpace }) => (
                    <span class={`flip-char inline-block ${isSpace ? 'mr-[0.2em]' : ''}`} style="perspective: 1000px;">
                      <span class="inline-block inner-char">{char}</span>
                    </span>
                  ))}
                </span>
              </h1>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-muted font-medium leading-relaxed max-w-sm">
                {heroSubtitle}
              </p>
            </div>

            {/* Phase 1: Career Impact */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-why">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-blue mb-6 lg:mb-8">Career Impact</h2>
              <h3 class="text-3xl md:text-5xl lg:text-6xl xl:text-7xl font-black text-primary leading-[0.9] tracking-tighter">
                Land the <br/><span class="text-brand-blue">Dream Job.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-muted font-medium max-w-sm leading-relaxed">
                From the first rhythm to your first day in the OR, we guide you to a career with purpose, impact, and security.
              </p>
            </div>

            {/* Phase 2: The Experience */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-how">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-yellow mb-6 lg:mb-8">The Experience</h2>
              <h3 class="text-3xl md:text-5xl lg:text-6xl xl:text-7xl font-black text-primary leading-[0.9] tracking-tighter">
                Mentorship <br/><span class="text-brand-yellow">is the key.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-muted font-medium max-w-sm leading-relaxed">
                Skip the "content drops." We pair you with industry veterans who coach you through every step of your transition.
              </p>
            </div>

            {/* Phase 3: Next Steps */}
            <div class="narrative-phase absolute inset-0 flex flex-col justify-center opacity-0 pointer-events-none" id="phase-cta">
              <h2 class="text-[10px] lg:text-[11px] font-black uppercase tracking-[0.4em] text-brand-green mb-6 lg:mb-8">Next Steps</h2>
              <h3 class="text-3xl md:text-5xl lg:text-6xl xl:text-7xl font-black text-primary leading-[0.9] tracking-tighter">
                Start your <br/><span class="text-brand-green">Journey Today.</span>
              </h3>
              <p class="mt-6 lg:mt-10 text-sm md:text-lg lg:text-xl text-muted font-medium max-w-sm leading-relaxed">
                The medical device industry is waiting. Take the first step toward your new career.
              </p>
              <div class="mt-10 flex flex-wrap gap-4">
                  <a href={`${import.meta.env.BASE_URL}apply`} class="px-8 py-4 rounded-full bg-brand-green text-xs font-black uppercase tracking-widest hover:bg-brand-green/90 transition-all shadow-xl shadow-brand-green/20 text-white">Apply Now</a>
              </div>
            </div>

          </div>
        </div>

        <div class="flex-1 relative bg-surface/10 flex items-center justify-center overflow-hidden">
            {/* Phase 0: The Foundation - Clinical Monitor Background */}
            <div class="visual-phase absolute inset-0 opacity-100" id="visual-hero">
                <div class="absolute inset-0 p-8 lg:p-12 overflow-hidden">
                    <div class="w-full h-full relative border border-brand-green/10 rounded-2xl bg-brand-green/[0.02]">
                        {/* Clinical Monitoring Grid */}
                        <div class="absolute inset-0 opacity-20" style="background-image: linear-gradient(#52cf95 1px, transparent 1px), linear-gradient(90deg, #52cf95 1px, transparent 1px); background-size: 20px 20px;"></div>
                        
                        {/* Monitoring Header */}
                        <div class="absolute top-4 left-6 right-6 flex justify-between items-start font-mono text-[8px] tracking-[0.2em] text-brand-green/60 uppercase">
                            <div class="flex flex-col gap-1">
                                <span class="text-brand-green font-black">Lead II // Sensing</span>
                                <span>Gain: 10mm/mV</span>
                            </div>
                            <div class="text-right flex flex-col gap-1">
                                <span>Mode: VVI // 60 BPM</span>
                                <span class="text-brand-green font-black" id="monitor-clock">00:00:00</span>
                            </div>
                        </div>

                        {/* Waveform Area */}
                        <div class="absolute inset-0 flex items-center justify-center">
                            <svg class="w-full h-48 lg:h-64" viewBox="0 0 800 200" preserveAspectRatio="none">
                                <defs>
                                    <clipPath id="monitor-clip">
                                        <rect id="monitor-clip-rect" x="0" y="0" width="0" height="200" />
                                    </clipPath>
                                    
                                    <linearGradient id="scan-gradient" x1="0" y1="0" x2="1" y2="0">
                                        <stop offset="0%" stop-color="#52cf95" stop-opacity="0" />
                                        <stop offset="60%" stop-color="#52cf95" stop-opacity="0.1" />
                                        <stop offset="100%" stop-color="#52cf95" stop-opacity="0.4" />
                                    </linearGradient>

                                    {/* Bloom effect for the leading edge */}
                                    <filter id="wave-bloom">
                                        <feGaussianBlur stdDeviation="2" result="blur" />
                                        <feComposite in="SourceGraphic" in2="blur" operator="over" />
                                    </filter>
                                </defs>

                                <path id="monitor-wave" d="M0,100 L100,100 L110,80 L125,120 L135,100 L250,100 L260,30 L280,170 L300,100 L450,100 L460,85 L475,115 L485,100 L600,100 L610,30 L630,170 L650,100 L800,100" stroke="#52cf95" stroke-width="2" fill="none" class="opacity-30" />
                                
                                <g clip-path="url(#monitor-clip)">
                                    <path id="monitor-wave-active" d="M0,100 L100,100 L110,80 L125,120 L135,100 L250,100 L260,30 L280,170 L300,100 L450,100 L460,85 L475,115 L485,100 L600,100 L610,30 L630,170 L650,100 L800,100" stroke="#52cf95" stroke-width="3" fill="none" class="drop-shadow-[0_0_12px_rgba(82,207,149,0.6)]" filter="url(#wave-bloom)" />
                                </g>
                                
                                {/* Scanning line - Positioned to lead the reveal */}
                                <rect id="monitor-scan" x="-80" y="0" width="80" height="200" fill="url(#scan-gradient)" />
                            </svg>
                        </div>

                        {/* Calibration Markers */}
                        <div class="absolute bottom-6 left-6 right-6 flex justify-around opacity-30">
                            {[...Array(5)].map((_, i) => (
                                <div class="w-px h-8 bg-brand-green/40 relative">
                                    <span class="absolute -top-4 left-1/2 -translate-x-1/2 font-mono text-[6px] text-brand-green">{i * 200}ms</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>

            <div class="absolute inset-0 flex items-center justify-center p-6 lg:p-20">
                {/* Phase 1: Career Impact - EKG */}
                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-why">
                    <div class="w-full max-w-lg aspect-[2/1] relative flex items-center justify-center">
                        <svg class="w-full h-full" viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path id="ekg-line" d="M0,100 L150,100 L160,80 L175,120 L185,100 L250,100 L265,20 L285,180 L305,100 L400,100" stroke="#3B3CFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-[0_0_8px_rgba(59,60,255,0.5)]" />
                        </svg>
                    </div>
                </div>

                {/* Phase 2: The Experience - Connecting Leads */}
                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-how">
                    <div class="w-full max-w-lg aspect-square relative flex items-center justify-center">
                        <div id="lead-left" class="absolute left-0 w-1/3 h-px bg-gradient-to-r from-transparent to-brand-yellow">
                            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-brand-yellow shadow-[0_0_15px_#FFE000]"></div>
                        </div>
                        <div id="lead-right" class="absolute right-0 w-1/3 h-px bg-gradient-to-l from-transparent to-brand-yellow">
                            <div class="absolute left-0 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-brand-yellow shadow-[0_0_15px_#FFE000]"></div>
                        </div>
                        <div id="lead-spark" class="w-4 h-4 rounded-full bg-brand-yellow opacity-0 scale-0 shadow-[0_0_30px_#FFE000]"></div>
                    </div>
                </div>

                {/* Phase 3: Next Steps - Activation Node */}
                <div class="visual-phase absolute inset-0 flex items-center justify-center opacity-0 scale-90" id="visual-cta">
                    <div class="relative w-48 h-48 flex items-center justify-center">
                        <div id="node-outer" class="absolute inset-0 rounded-full border-2 border-brand-green/20"></div>
                        <div id="node-middle" class="absolute inset-4 rounded-full border-2 border-brand-green/40"></div>
                        <div id="node-inner" class="w-16 h-16 rounded-full bg-brand-green shadow-[0_0_40px_rgba(82,207,149,0.4)] flex items-center justify-center">
                             <div class="w-8 h-8 rounded-full bg-white/20 animate-ping"></div>
                        </div>
                        <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 100 100">
                            <circle id="node-sweep" cx="50" cy="50" r="48" fill="none" stroke="#52cf95" stroke-width="2" stroke-dasharray="301.59" stroke-dashoffset="301.59" stroke-linecap="round" />
                        </svg>
                    </div>
                </div>
            </div>
        </div>

      </div>

      <div class="h-auto lg:h-32 border-t border-primary/5 bg-surface/20 px-6 py-4 lg:py-0 lg:px-20">
        <div class="h-full w-full mx-auto flex flex-col md:flex-row items-center justify-between gap-4 md:gap-0">
          <div class="flex flex-col text-center md:text-left w-full md:w-auto">
              <span class="text-[8px] lg:text-[10px] font-black uppercase tracking-[0.2em] text-muted">Journey Phase</span>
              <span class="text-xs lg:text-sm font-black uppercase text-brand-green" id="journey-phase-label">The Foundation</span>
          </div>

          <div class="flex flex-col md:flex-row gap-4 lg:gap-8 items-center w-full md:w-auto">
              <a href={`${import.meta.env.BASE_URL}curriculum`} class="text-[8px] lg:text-[10px] font-black uppercase tracking-widest text-secondary hover:text-primary transition-colors w-full md:w-auto text-center border border-primary/10 md:border-none rounded-full px-6 py-3 md:p-0">Explore Curriculum</a>
              <a href={`${import.meta.env.BASE_URL}apply`} class="w-full md:w-auto px-10 py-3 lg:py-4 rounded-full bg-brand-blue text-[8px] lg:text-[10px] font-black uppercase tracking-widest hover:bg-brand-blue/90 transition-all shadow-xl shadow-brand-blue/20 text-center text-white">Apply Now</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  window.addEventListener('load', () => {
    const wrapper = document.querySelector('#scrolly-journey-wrapper');
    const cardContainer = document.querySelector('#scrolly-journey-card-container');
    if (!wrapper || !cardContainer) return;

    const phases = [
        { id: 'hero', label: 'THE FOUNDATION', color: '#52cf95' },
        { id: 'why', label: 'CAREER IMPACT', color: '#3B3CFF' },
        { id: 'how', label: 'THE EXPERIENCE', color: '#FFE000' },
        { id: 'cta', label: 'NEXT STEPS', color: '#52cf95' }
    ];

    const phaseLabel = document.querySelector('#journey-phase-label');
    let currentPhaseIndex = 0;
    let isNavigating = false;

    // Initial Flip Animation for Hero Title & HUD
    const flipChars = document.querySelectorAll('.flip-char .inner-char');
    gsap.from(flipChars, {
      rotateX: -90,
      opacity: 0,
      y: 20,
      duration: 0.8,
      stagger: 0.05,
      ease: "back.out(1.7)",
      delay: 0.5
    });

    const animateMedicalMonitor = () => {
        const totalWidth = 800;
        const scanWidth = 80;

        // Unified animation for perfect synchronization in SVG space
        gsap.to({}, {
            duration: 4,
            repeat: -1,
            ease: "none",
            overwrite: 'auto',
            onUpdate: function() {
                const progress = this.progress();
                const x = progress * totalWidth;
                
                const scan = document.querySelector('#monitor-scan');
                const clipRect = document.querySelector('#monitor-clip-rect');
                
                if (scan instanceof SVGElement) {
                    // Position scan so its leading edge (right) is at x
                    scan.setAttribute('x', (x - scanWidth).toString());
                }
                
                if (clipRect instanceof SVGElement) {
                    // Reveal exactly up to x
                    clipRect.setAttribute('width', x.toString());
                }
            }
        });

        // Subtly pulse the active wave brightness
        gsap.to('#monitor-wave-active', {
            opacity: 0.8,
            duration: 0.1,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });

        // Running Clock
        const clock = document.querySelector('#monitor-clock');
        if (clock) {
            let seconds = 0;
            const updateClock = () => {
                seconds++;
                const mins = Math.floor(seconds / 60).toString().padStart(2, '0');
                const secs = (seconds % 60).toString().padStart(2, '0');
                const ms = Math.floor(Math.random() * 99).toString().padStart(2, '0');
                clock.textContent = `00:${mins}:${secs}:${ms}`;
            };
            const clockInterval = setInterval(updateClock, 1000);
            return () => clearInterval(clockInterval);
        }
    };

    animateMedicalMonitor();

    const updatePhaseLabel = (index) => {
        const { label, color } = phases[index];
        if (!phaseLabel) return;
        
        phaseLabel.innerHTML = '';
        label.split('').forEach((char) => {
            const span = document.createElement('span');
            span.className = 'flip-char inline-block';
            if (char === ' ') {
                span.classList.add('mr-[0.2em]');
                span.innerHTML = '<span class="inline-block inner-char">&nbsp;</span>';
            } else {
                span.innerHTML = `<span class="inline-block inner-char">${char}</span>`;
            }
            span.style.perspective = '1000px';
            const inner = span.querySelector('.inner-char');
            if (inner instanceof HTMLElement) inner.style.color = color;
            phaseLabel.appendChild(span);
        });

        gsap.fromTo(phaseLabel.querySelectorAll('.inner-char'), 
            { rotateX: -90, opacity: 0, y: 10 },
            { 
                rotateX: 0, 
                opacity: 1, 
                y: 0, 
                duration: 0.4, 
                stagger: 0.03, 
                ease: "back.out(1.7)",
                overwrite: true 
            }
        );
    };

    const goToPhase = (index) => {
        if (index === currentPhaseIndex) return;
        
        const prev = phases[currentPhaseIndex];
        const next = phases[index];
        currentPhaseIndex = index;

        // Exit Previous
        gsap.to(`#phase-${prev.id}`, { opacity: 0, y: -40, duration: 0.6, pointerEvents: 'none', overwrite: 'auto' });
        gsap.to(`#visual-${prev.id}`, { opacity: 0, scale: 0.85, duration: 0.6, overwrite: 'auto' });

        // Enter Next
        gsap.to(`#phase-${next.id}`, { opacity: 1, y: 0, duration: 0.8, pointerEvents: 'auto', delay: 0.1, overwrite: 'auto' });
        gsap.to(`#visual-${next.id}`, { opacity: 1, scale: 1, duration: 0.8, delay: 0.1, overwrite: 'auto' });

        // Phase Specific Animations
        if (next.id === 'hero') {
            animateMedicalMonitor();
        } else if (next.id === 'why') {
            gsap.fromTo('#ekg-line', 
                { strokeDasharray: 1000, strokeDashoffset: 1000 }, 
                { strokeDashoffset: 0, duration: 2, ease: "power2.out", delay: 0.2 }
            );
        } else if (next.id === 'how') {
            gsap.fromTo('#lead-left', { x: -50, opacity: 0 }, { x: 0, opacity: 1, duration: 0.8, ease: "back.out(1.7)", delay: 0.3 });
            gsap.fromTo('#lead-right', { x: 50, opacity: 0 }, { x: 0, opacity: 1, duration: 0.8, ease: "back.out(1.7)", delay: 0.3 });
            gsap.to('#lead-spark', { 
                scale: 4, 
                opacity: 0.8, 
                duration: 0.4, 
                delay: 1, 
                onComplete: () => {
                    gsap.to('#lead-spark', { scale: 0, opacity: 0, duration: 0.3 });
                }
            });
        } else if (next.id === 'cta') {
            gsap.fromTo('#node-sweep', 
                { strokeDashoffset: 301.59 }, 
                { strokeDashoffset: 0, duration: 1.5, ease: "power1.inOut", delay: 0.4 }
            );
            gsap.to('#node-inner', { 
                scale: 1.1, 
                duration: 0.6, 
                repeat: -1, 
                yoyo: true, 
                ease: "sine.inOut",
                delay: 1.5
            });
        }

        updatePhaseLabel(index);
    };

    // Initialize the first label
    updatePhaseLabel(0);

    const st = ScrollTrigger.create({
        trigger: wrapper,
        start: 'top top',
        end: '+=300%',
        pin: true,
        snap: {
            snapTo: [0, 0.33, 0.66, 1],
            duration: { min: 0.2, max: 0.5 },
            delay: 0.05,
            ease: "power2.inOut"
        },
        onUpdate: (self) => {
            if (isNavigating) return;
            const p = self.progress;
            let newIndex = 0;
            if (p > 0.83) newIndex = 3;
            else if (p > 0.49) newIndex = 2;
            else if (p > 0.16) newIndex = 1;
            
            if (newIndex !== currentPhaseIndex) {
                goToPhase(newIndex);
            }
        }
    });

    // Keyboard Navigation
    window.addEventListener('keydown', (e) => {
        if (!st.isActive || isNavigating) return;

        let targetIndex = -1;
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
            if (currentPhaseIndex < phases.length - 1) {
                targetIndex = currentPhaseIndex + 1;
            }
        } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
            if (currentPhaseIndex > 0) {
                targetIndex = currentPhaseIndex - 1;
            }
        }

        if (targetIndex !== -1) {
            e.preventDefault();
            isNavigating = true;
            const targetProgress = targetIndex / (phases.length - 1);
            const targetScroll = st.start + (targetProgress * (st.end - st.start));
            
            gsap.to(window, { 
                scrollTo: targetScroll, 
                duration: 0.6, 
                ease: "power2.inOut",
                onComplete: () => {
                    // Small delay to allow onUpdate to settle
                    setTimeout(() => { isNavigating = false; }, 50);
                }
            });
        }
    });
  });
</script>

<style>
  .narrative-phase, .visual-phase {
    will-change: opacity, transform;
  }
  .inner-char {
    display: inline-block;
    transform-origin: center bottom;
  }
</style>