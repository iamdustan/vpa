---
---

<div class="relative py-24 lg:py-48" id="journey-container">
  <div class="sticky top-0 h-screen flex flex-col justify-center items-center overflow-hidden">
    
    {/* Background Bridge Element */}
    <div id="bridge-visual" class="absolute w-[200%] h-2 bg-gradient-to-r from-indigo-500 via-purple-500 to-cyan-500 opacity-20 blur-sm -rotate-6"></div>
    
    {/* Story Sections */}
    <div class="relative w-full max-w-4xl px-4 text-center">
      <div class="story-step opacity-0 translate-y-10" id="step-1">
        <h3 class="text-4xl md:text-6xl font-bold text-white mb-6">The Current State</h3>
        <p class="text-xl text-slate-400">Feeling stuck in a career that lacks impact? You have the drive, but not the bridge to MedTech.</p>
      </div>
      
      <div class="story-step absolute inset-0 flex flex-col justify-center items-center opacity-0 translate-y-10" id="step-2">
        <h3 class="text-4xl md:text-6xl font-bold text-white mb-6">The Connection</h3>
        <p class="text-xl text-slate-400">VPA provides the mentorship and technical mastery to bridge that gap. 1-on-1 coaching with industry legends.</p>
      </div>
      
      <div class="story-step absolute inset-0 flex flex-col justify-center items-center opacity-0 translate-y-10" id="step-3">
        <h3 class="text-4xl md:text-6xl font-bold text-white mb-6">The Outcome</h3>
        <p class="text-xl text-slate-400">A high-impact career as a Clinical Specialist. Life-saving technology, supported by a lifelong network.</p>
      </div>
    </div>
  </div>
  
  {/* Spacer to create scroll length */}
  <div class="h-[300vh]"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector('#journey-container');
  const steps = gsap.utils.toArray('.story-step');
  const bridge = document.querySelector('#bridge-visual');

  if (container) {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        pin: true,
      }
    });

    // Step 1: Current State
    tl.to('#step-1', { opacity: 1, y: 0, duration: 1 });
    tl.to('#bridge-visual', { scaleX: 1.5, opacity: 0.4, rotate: -2, duration: 2 }, "<");
    tl.to('#step-1', { opacity: 0, y: -20, duration: 1, delay: 1 });

    // Step 2: The Connection
    tl.to('#step-2', { opacity: 1, y: 0, duration: 1 });
    tl.to('#bridge-visual', { scaleX: 2, opacity: 0.6, rotate: 0, duration: 2 }, "<");
    tl.to('#step-2', { opacity: 0, y: -20, duration: 1, delay: 1 });

    // Step 3: The Outcome
    tl.to('#step-3', { opacity: 1, y: 0, duration: 1 });
    tl.to('#bridge-visual', { scaleX: 2.5, opacity: 1, rotate: 2, filter: 'blur(0px)', duration: 2 }, "<");
  }
</script>
