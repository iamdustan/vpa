---
import '../styles/global.css';
import { initPostHog } from '../lib/analytics';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Virtual Pacing Academy - The Mentorship Bridge to a Career in MedTech" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-page-bg text-white antialiased selection:bg-brand-blue/30">
		<script>
			import { initPostHog } from '../lib/analytics';
			initPostHog();
		</script>
		<nav class="fixed top-0 z-50 w-full px-6 py-8 pointer-events-none">
			<div class="mx-auto flex max-w-[1600px] items-center justify-between pointer-events-auto">
				<div class="flex items-center gap-2">
					<a href="/" class="text-2xl font-black tracking-tighter text-white uppercase">VPA</a>
				</div>
				<div class="hidden space-x-10 md:flex items-center bg-background/50 backdrop-blur-xl px-8 py-3 rounded-full border border-white/5">
					<a href="/jobs" class="text-xs font-black uppercase tracking-[0.2em] text-white/50 transition-colors hover:text-white">Jobs</a>
					<a href="/curriculum" class="text-xs font-black uppercase tracking-[0.2em] text-white/50 transition-colors hover:text-white">Curriculum</a>
					<a href="/admissions" class="text-xs font-black uppercase tracking-[0.2em] text-white/50 transition-colors hover:text-white">Admissions</a>
					<a href="/apply" class="text-xs font-black text-brand-blue uppercase tracking-widest hover:text-white transition-colors">Apply Now</a>
				</div>
			</div>
		</nav>
		<main>
			<slot />
		</main>
		<footer class="border-t border-white/10 py-12">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="flex flex-col items-center justify-between gap-6 md:flex-row">
					<p class="text-sm text-slate-500">&copy; {new Date().getFullYear()} Virtual Pacing Academy. All rights reserved.</p>
					<div class="flex space-x-6">
						<a href="/privacy" class="text-sm text-slate-500 hover:text-slate-300">Privacy</a>
						<a href="/terms" class="text-sm text-slate-500 hover:text-slate-300">Terms</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
